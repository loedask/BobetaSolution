<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Bobeta.Mobile.Pages.CreateGamePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{StaticResource PageBackground}"
    Title="Create">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">
            <Label x:Name="HeaderLabel" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Foreground}" />
            <Label x:Name="DescLabel" FontSize="14" TextColor="{StaticResource MutedForeground}" />
            <Border x:Name="InviteBanner" IsVisible="False" Padding="12" BackgroundColor="{StaticResource Card}" StrokeShape="RoundRectangle 12">
                <Label x:Name="InviteBannerLabel" FontSize="13" TextColor="{StaticResource PrimaryGold}" />
            </Border>
            <VerticalStackLayout x:Name="InviteEntryPanel" Spacing="8" IsVisible="False">
                <Label x:Name="InviteHaveCodeLabel" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource Foreground}" />
                <Label x:Name="InviteHintLabel" FontSize="12" TextColor="{StaticResource MutedForeground}" />
                <Label x:Name="InviteSuccessLabel" IsVisible="False" FontSize="12" TextColor="{StaticResource AccentGreen}" />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <Entry
                        x:Name="InviteCodeEntry"
                        Placeholder="CODE"
                        Text="{Binding InviteCodeInput, Mode=TwoWay}"
                        TextColor="{StaticResource Foreground}"
                        BackgroundColor="{StaticResource Card}" />
                    <Button
                        x:Name="InviteApplyBtn"
                        Grid.Column="1"
                        Clicked="OnApplyInvite"
                        CornerRadius="10"
                        BackgroundColor="{StaticResource PrimaryGold}"
                        TextColor="{StaticResource PrimaryDarkText}" />
                </Grid>
            </VerticalStackLayout>
            <Label x:Name="GameTypeLabel" FontSize="12" TextColor="{StaticResource MutedForeground}" />
            <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="6" RowSpacing="6">
                <Button x:Name="MakopaBtn" Clicked="OnMakopaVariant" CornerRadius="10" FontSize="12" />
                <Button x:Name="KopoBtn" Grid.Column="1" Clicked="OnKopoVariant" CornerRadius="10" FontSize="12" />
                <Button x:Name="NgolaBtn" Grid.Column="2" Clicked="OnNgolaVariant" CornerRadius="10" FontSize="12" />
                <Button x:Name="DominoBtn" Grid.Row="1" Clicked="OnDominoVariant" CornerRadius="10" FontSize="12" />
                <Button x:Name="AbbiaBtn" Grid.Row="1" Grid.Column="1" Clicked="OnAbbiaVariant" CornerRadius="10" FontSize="12" />
            </Grid>
            <Label x:Name="BetLabel" FontSize="12" TextColor="{StaticResource MutedForeground}" />
            <Entry
                Text="{Binding BetAmount, Mode=TwoWay}"
                Keyboard="Numeric"
                FontSize="24"
                HorizontalTextAlignment="Center"
                TextColor="{StaticResource Foreground}"
                BackgroundColor="{StaticResource Card}" />
            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                <Button Clicked="OnPreset" Text="200" CornerRadius="10" BackgroundColor="{StaticResource SecondaryCard}" TextColor="{StaticResource Foreground}" />
                <Button Grid.Column="1" Clicked="OnPreset" Text="300" CornerRadius="10" BackgroundColor="{StaticResource SecondaryCard}" TextColor="{StaticResource Foreground}" />
                <Button Grid.Column="2" Clicked="OnPreset" Text="400" CornerRadius="10" BackgroundColor="{StaticResource SecondaryCard}" TextColor="{StaticResource Foreground}" />
                <Button Grid.Column="3" Clicked="OnPreset" Text="500" CornerRadius="10" BackgroundColor="{StaticResource SecondaryCard}" TextColor="{StaticResource Foreground}" />
            </Grid>
            <Label x:Name="YouPayLabel" IsVisible="False" FontSize="12" TextColor="{StaticResource MutedForeground}" HorizontalTextAlignment="Center" />
            <Label x:Name="ErrorLabel" IsVisible="False" TextColor="{StaticResource Destructive}" />
            <Button
                x:Name="CreateBtn"
                Clicked="OnCreate"
                CornerRadius="14"
                FontAttributes="Bold"
                HeightRequest="52"
                BackgroundColor="{StaticResource PrimaryGold}"
                TextColor="{StaticResource PrimaryDarkText}" />
            <ActivityIndicator x:Name="Busy" IsRunning="False" Color="{StaticResource PrimaryGold}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
