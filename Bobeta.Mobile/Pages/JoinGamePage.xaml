<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Bobeta.Mobile.Pages.JoinGamePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{StaticResource PageBackground}"
    Title="Join">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" Padding="16" RowSpacing="12">
        <Border x:Name="InviteBanner" IsVisible="False" Padding="12" BackgroundColor="{StaticResource Card}" StrokeShape="RoundRectangle 12">
            <Label x:Name="InviteBannerLabel" FontSize="13" TextColor="{StaticResource PrimaryGold}" />
        </Border>
        <VerticalStackLayout x:Name="InviteEntryPanel" Grid.Row="1" Spacing="8" IsVisible="False">
            <Label x:Name="InviteHaveCodeLabel" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource Foreground}" />
            <Label x:Name="InviteHintLabel" FontSize="12" TextColor="{StaticResource MutedForeground}" />
            <Label x:Name="InviteSuccessLabel" IsVisible="False" FontSize="12" TextColor="{StaticResource AccentGreen}" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Entry
                    x:Name="InviteCodeEntry"
                    Placeholder="CODE"
                    Text="{Binding InviteCodeInput, Mode=TwoWay}"
                    TextColor="{StaticResource Foreground}"
                    BackgroundColor="{StaticResource Card}" />
                <Button
                    x:Name="InviteApplyBtn"
                    Grid.Column="1"
                    Clicked="OnApplyInvite"
                    CornerRadius="10"
                    BackgroundColor="{StaticResource PrimaryGold}"
                    TextColor="{StaticResource PrimaryDarkText}" />
            </Grid>
        </VerticalStackLayout>
        <HorizontalStackLayout Grid.Row="2" Spacing="8">
            <Button x:Name="FilterAllBtn" Clicked="OnFilterAll" CornerRadius="8" FontSize="12" Padding="12,6" />
            <Button x:Name="FilterMakopaBtn" Clicked="OnFilterMakopa" CornerRadius="8" FontSize="12" Padding="12,6" />
            <Button x:Name="FilterKopoBtn" Clicked="OnFilterKopo" CornerRadius="8" FontSize="12" Padding="12,6" />
            <Button x:Name="FilterNgolaBtn" Clicked="OnFilterNgola" CornerRadius="8" FontSize="12" Padding="12,6" />
            <Button x:Name="FilterDominoBtn" Clicked="OnFilterDomino" CornerRadius="8" FontSize="12" Padding="12,6" />
        </HorizontalStackLayout>
        <Grid Grid.Row="3" ColumnDefinitions="*,Auto">
            <Label x:Name="Subtitle" FontSize="14" TextColor="{StaticResource MutedForeground}" VerticalOptions="Center" />
            <Button
                x:Name="RefreshBtn"
                Grid.Column="1"
                Clicked="OnRefresh"
                BackgroundColor="Transparent"
                TextColor="{StaticResource PrimaryGold}"
                FontSize="13" />
        </Grid>
        <CollectionView x:Name="GamesList" Grid.Row="4" ItemsSource="{Binding OpenGames}">
            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="24" Spacing="12" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label
                        x:Name="EmptyLabel"
                        HorizontalTextAlignment="Center"
                        TextColor="{StaticResource MutedForeground}" />
                    <Label
                        x:Name="ViewWaitingLink"
                        HorizontalTextAlignment="Center"
                        FontSize="13"
                        FontAttributes="Bold"
                        TextColor="{StaticResource PrimaryGold}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnViewWaitingTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,10" Padding="16" BackgroundColor="{StaticResource Card}" StrokeShape="RoundRectangle 14">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="4">
                                <HorizontalStackLayout Spacing="8">
                                    <Label Text="Player" FontSize="12" TextColor="{StaticResource MutedForeground}" />
                                    <Label Text="{Binding VariantName}" FontSize="11" TextColor="{StaticResource PrimaryGold}" />
                                </HorizontalStackLayout>
                                <Label Text="{Binding BetAmount, StringFormat='{0:N0} FCFA'}" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource PrimaryGold}" />
                            </VerticalStackLayout>
                            <Button
                                Grid.Column="1"
                                Clicked="OnJoinOne"
                                Text="Join"
                                VerticalOptions="Center"
                                BackgroundColor="{StaticResource AccentGreen}"
                                TextColor="{StaticResource PrimaryDarkText}"
                                CornerRadius="10"
                                Padding="16,8" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <VerticalStackLayout
            x:Name="ErrorPanel"
            Grid.Row="4"
            IsVisible="False"
            Spacing="8"
            VerticalOptions="Start">
            <Label x:Name="ErrorLabel" TextColor="{StaticResource Destructive}" />
            <Button
                x:Name="LiveGamesActionBtn"
                IsVisible="False"
                Clicked="OnLiveGamesAction"
                HorizontalOptions="Start"
                FontSize="13"
                Padding="12,8"
                CornerRadius="10"
                BackgroundColor="{StaticResource Card}"
                TextColor="{StaticResource Destructive}" />
        </VerticalStackLayout>
        <ActivityIndicator x:Name="Busy" Grid.Row="4" IsRunning="False" Color="{StaticResource PrimaryGold}" VerticalOptions="Center" HorizontalOptions="Center" />
    </Grid>
</ContentPage>
