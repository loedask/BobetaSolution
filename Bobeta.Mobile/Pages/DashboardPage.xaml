<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Bobeta.Mobile.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{StaticResource PageBackground}"
    Title="Home">

    <Grid RowDefinitions="Auto,*" Padding="16,8" RowSpacing="12">
        <Grid ColumnDefinitions="*,Auto">
            <VerticalStackLayout Spacing="4">
                <Label x:Name="WelcomePrefix" FontSize="13" TextColor="{StaticResource MutedForeground}" />
                <Label Text="{Binding PlayerName}" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource Foreground}" />
            </VerticalStackLayout>
            <Grid Grid.Column="1" WidthRequest="44" HeightRequest="44" VerticalOptions="Center">
                <Button
                    x:Name="BellBtn"
                    Clicked="OnOpenInbox"
                    CornerRadius="12"
                    BackgroundColor="{StaticResource Card}"
                    Text="🔔"
                    FontSize="16"
                    TextColor="{StaticResource MutedForeground}" />
                <Ellipse
                    x:Name="UnreadDot"
                    WidthRequest="10"
                    HeightRequest="10"
                    Fill="{StaticResource AccentGreen}"
                    HorizontalOptions="End"
                    VerticalOptions="Start"
                    Margin="0,2,2,0"
                    IsVisible="False" />
            </Grid>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="16">
                <Label x:Name="ErrorLabel" IsVisible="False" TextColor="{StaticResource Destructive}" FontSize="13" />
                <Border x:Name="InvitePromptPanel" IsVisible="False" Padding="14" BackgroundColor="{StaticResource Card}" StrokeShape="RoundRectangle 14">
                    <VerticalStackLayout Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="4">
                                <Label x:Name="InviteHaveCodeLabel" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource Foreground}" />
                                <Label x:Name="InviteHintLabel" FontSize="12" TextColor="{StaticResource MutedForeground}" />
                            </VerticalStackLayout>
                            <Button
                                x:Name="InviteDismissBtn"
                                Grid.Column="1"
                                Clicked="OnDismissInvite"
                                BackgroundColor="Transparent"
                                TextColor="{StaticResource MutedForeground}"
                                FontSize="12"
                                VerticalOptions="Start" />
                        </Grid>
                        <Label x:Name="InviteSuccessLabel" IsVisible="False" FontSize="12" TextColor="{StaticResource AccentGreen}" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Entry
                                x:Name="InviteCodeEntry"
                                Placeholder="CODE"
                                Text="{Binding InviteCodeInput, Mode=TwoWay}"
                                TextColor="{StaticResource Foreground}"
                                BackgroundColor="{StaticResource SecondaryCard}" />
                            <Button
                                x:Name="InviteApplyBtn"
                                Grid.Column="1"
                                Clicked="OnApplyInvite"
                                CornerRadius="10"
                                BackgroundColor="{StaticResource PrimaryGold}"
                                TextColor="{StaticResource PrimaryDarkText}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
                <Border x:Name="InvitePendingBanner" IsVisible="False" Padding="12" BackgroundColor="{StaticResource Card}" StrokeShape="RoundRectangle 12">
                    <Label x:Name="InvitePendingLabel" FontSize="13" TextColor="{StaticResource PrimaryGold}" />
                </Border>
                <Border Padding="20" BackgroundColor="{StaticResource Card}" Stroke="{StaticResource Border}" StrokeThickness="1" StrokeShape="RoundRectangle 16">
                    <VerticalStackLayout Spacing="12">
                        <Label x:Name="WalletTitle" FontSize="13" TextColor="{StaticResource MutedForeground}" />
                        <Label Text="{Binding Balance, StringFormat='{0:N0} FCFA'}" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource PrimaryGold}" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Button
                                x:Name="DepositBtn"
                                Clicked="OnDeposit"
                                CornerRadius="12"
                                BackgroundColor="{StaticResource PrimaryGold}"
                                TextColor="{StaticResource PrimaryDarkText}" />
                            <Button
                                x:Name="WithdrawBtn"
                                Grid.Column="1"
                                Clicked="OnWithdraw"
                                CornerRadius="12"
                                BackgroundColor="{StaticResource SecondaryCard}"
                                TextColor="{StaticResource Foreground}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8" RowDefinitions="Auto,Auto" RowSpacing="8">
                    <Button
                        x:Name="CreateTile"
                        Grid.Row="0"
                        Grid.Column="0"
                        Clicked="OnGoCreate"
                        CornerRadius="12"
                        HeightRequest="72"
                        FontSize="11"
                        BackgroundColor="{StaticResource PrimaryGold}"
                        TextColor="{StaticResource PrimaryDarkText}" />
                    <Button
                        x:Name="JoinTile"
                        Grid.Row="0"
                        Grid.Column="1"
                        Clicked="OnGoJoin"
                        CornerRadius="12"
                        HeightRequest="72"
                        FontSize="11"
                        BackgroundColor="{StaticResource AccentGreen}"
                        TextColor="{StaticResource PrimaryDarkText}" />
                    <Button
                        x:Name="WaitingTile"
                        Grid.Row="1"
                        Grid.Column="0"
                        Clicked="OnGoWaiting"
                        CornerRadius="12"
                        HeightRequest="72"
                        FontSize="11"
                        BackgroundColor="{StaticResource SecondaryCard}"
                        TextColor="{StaticResource Foreground}" />
                    <Button
                        x:Name="HistoryTile"
                        Grid.Row="1"
                        Grid.Column="1"
                        Clicked="OnGoHistory"
                        CornerRadius="12"
                        HeightRequest="72"
                        FontSize="11"
                        BackgroundColor="{StaticResource SecondaryCard}"
                        TextColor="{StaticResource Foreground}" />
                </Grid>

                <Grid ColumnDefinitions="*,Auto">
                    <Label x:Name="RecentTitle" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource Foreground}" />
                    <Button
                        x:Name="SeeAllBtn"
                        Grid.Column="1"
                        Clicked="OnGoHistory"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource PrimaryGold}"
                        FontSize="13" />
                </Grid>

                <ActivityIndicator x:Name="Busy" IsRunning="False" Color="{StaticResource PrimaryGold}" />
                <CollectionView x:Name="TxList" ItemsSource="{Binding Transactions}" HeightRequest="360">
                    <CollectionView.EmptyView>
                        <Label x:Name="EmptyTx" TextColor="{StaticResource MutedForeground}" FontSize="13" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8" Padding="14" BackgroundColor="{StaticResource Card}" StrokeShape="RoundRectangle 12">
                                <Grid ColumnDefinitions="*,Auto">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="{Binding Description}" FontSize="14" TextColor="{StaticResource Foreground}" />
                                        <Label Text="{Binding Time}" FontSize="12" TextColor="{StaticResource MutedForeground}" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="1" Text="{Binding Amount, StringFormat='{0:N0}'}" FontAttributes="Bold" VerticalOptions="Center" TextColor="{StaticResource PrimaryGold}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label x:Name="TrustLabel" FontSize="11" TextColor="{StaticResource AccentGreen}" LineBreakMode="WordWrap" />
            </VerticalStackLayout>
        </ScrollView>

        <Grid
            x:Name="InboxOverlay"
            Grid.RowSpan="2"
            IsVisible="False"
            BackgroundColor="#CC0D0D0F">
            <Border
                Margin="16,48"
                Padding="0"
                VerticalOptions="Center"
                BackgroundColor="{StaticResource Card}"
                StrokeShape="RoundRectangle 16"
                MaximumHeightRequest="520">
                <Grid RowDefinitions="Auto,*,Auto" Padding="16" RowSpacing="12">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <VerticalStackLayout Spacing="2">
                            <Label x:Name="InboxTitle" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource Foreground}" />
                            <Label x:Name="InboxUnread" FontSize="12" TextColor="{StaticResource MutedForeground}" />
                        </VerticalStackLayout>
                        <Button
                            x:Name="MarkAllBtn"
                            Grid.Column="1"
                            Clicked="OnMarkAllRead"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource PrimaryGold}"
                            FontSize="12"
                            Margin="0,0,8,0" />
                        <Button
                            x:Name="CloseInboxBtn"
                            Grid.Column="2"
                            Clicked="OnCloseInbox"
                            Text="✕"
                            BackgroundColor="{StaticResource SecondaryCard}"
                            TextColor="{StaticResource Foreground}"
                            WidthRequest="36"
                            HeightRequest="36"
                            CornerRadius="10"
                            Padding="0" />
                    </Grid>
                    <CollectionView x:Name="InboxList" Grid.Row="1" SelectionMode="Single" SelectionChanged="OnInboxSelectionChanged">
                        <CollectionView.EmptyView>
                            <VerticalStackLayout Padding="16" Spacing="6">
                                <Label x:Name="InboxEmptyTitle" HorizontalTextAlignment="Center" TextColor="{StaticResource Foreground}" FontAttributes="Bold" />
                                <Label x:Name="InboxEmptyBody" HorizontalTextAlignment="Center" TextColor="{StaticResource MutedForeground}" FontSize="12" />
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8" Padding="12" BackgroundColor="{StaticResource SecondaryCard}" StrokeShape="RoundRectangle 12">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="{Binding Title}" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource Foreground}" />
                                        <Label Text="{Binding Body}" FontSize="12" TextColor="{StaticResource MutedForeground}" LineBreakMode="WordWrap" />
                                        <Label Text="{Binding Time}" FontSize="11" TextColor="{StaticResource MutedForeground}" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <Label x:Name="InboxError" Grid.Row="2" IsVisible="False" TextColor="{StaticResource Destructive}" FontSize="12" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
