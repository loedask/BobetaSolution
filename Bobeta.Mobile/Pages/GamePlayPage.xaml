<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Bobeta.Mobile.Pages.GamePlayPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:Bobeta.Mobile.Controls"
    x:Name="PageRoot"
    BackgroundColor="{StaticResource PageBackground}">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto,Auto" Padding="16" RowSpacing="12">
        <Border Grid.Row="0" Padding="14" BackgroundColor="{StaticResource Card}" StrokeShape="RoundRectangle 14">
            <VerticalStackLayout Spacing="8">
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                    <VerticalStackLayout Spacing="2" VerticalOptions="Start">
                        <Label x:Name="PotTableLabel" FontSize="10" TextColor="{StaticResource MutedForeground}" />
                        <Label
                            x:Name="PotTotalLabel"
                            FontSize="22"
                            FontAttributes="Bold"
                            TextColor="{StaticResource PrimaryGold}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout
                        Grid.Column="1"
                        Spacing="4"
                        HorizontalOptions="End"
                        VerticalOptions="Start">
                        <Label x:Name="PotSeatsLabel" FontSize="9" TextColor="{StaticResource MutedForeground}" HorizontalTextAlignment="End" />
                        <Border
                            x:Name="PotOpponentBadge"
                            Padding="8,6"
                            IsVisible="False"
                            HorizontalOptions="End"
                            BackgroundColor="#14EAB308"
                            Stroke="{StaticResource PrimaryGold}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 12">
                            <HorizontalStackLayout Spacing="8" HorizontalOptions="End">
                                <VerticalStackLayout Spacing="0" VerticalOptions="Center" HorizontalOptions="End">
                                    <Label x:Name="PotOpponentLaneLabel" FontSize="8" TextColor="{StaticResource PrimaryGold}" HorizontalTextAlignment="End" />
                                    <Label
                                        x:Name="PotOpponentNameLabel"
                                        FontSize="11"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource Foreground}"
                                        LineBreakMode="TailTruncation"
                                        MaxLines="1"
                                        WidthRequest="118"
                                        HorizontalTextAlignment="End" />
                                </VerticalStackLayout>
                                <Border
                                    WidthRequest="36"
                                    HeightRequest="36"
                                    StrokeShape="RoundRectangle 18"
                                    BackgroundColor="#33EAB308"
                                    Stroke="{StaticResource PrimaryGold}"
                                    StrokeThickness="1"
                                    VerticalOptions="Center">
                                    <Label
                                        x:Name="PotOpponentInitialsLabel"
                                        FontSize="11"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource PrimaryGold}"
                                        HorizontalTextAlignment="Center"
                                        VerticalTextAlignment="Center" />
                                </Border>
                            </HorizontalStackLayout>
                        </Border>
                        <HorizontalStackLayout Spacing="6" HorizontalOptions="End">
                            <Border
                                Padding="10,5"
                                BackgroundColor="#18EAB308"
                                Stroke="{StaticResource PrimaryGold}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 20">
                                <Label x:Name="ChipLeftText" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource PrimaryGold}" />
                            </Border>
                            <Label Text="+" VerticalOptions="Center" TextColor="{StaticResource MutedForeground}" FontAttributes="Bold" />
                            <Border
                                Padding="10,5"
                                BackgroundColor="#18EAB308"
                                Stroke="{StaticResource PrimaryGold}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 20">
                                <Label x:Name="ChipRightText" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource PrimaryGold}" />
                            </Border>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Grid>
                <BoxView HeightRequest="1" Color="#2A2F38" Margin="0,2,0,0" />
                <Label x:Name="PotHintLabel" FontSize="11" TextColor="{StaticResource MutedForeground}" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Border>

        <VerticalStackLayout x:Name="MakopaPanel" Grid.Row="1" Spacing="8" IsVisible="True">
            <HorizontalStackLayout Spacing="12" HorizontalOptions="Fill">
                <Label
                    x:Name="RoundScoreLabel"
                    FontSize="12"
                    FontAttributes="Bold"
                    TextColor="{StaticResource AccentGreen}"
                    HorizontalOptions="FillAndExpand"
                    LineBreakMode="WordWrap" />
                <Label
                    x:Name="RulesLink"
                    FontSize="12"
                    TextDecorations="Underline"
                    TextColor="{StaticResource PrimaryGold}"
                    VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRulesTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>
            <Label x:Name="LastPlayTitle" FontSize="12" TextColor="{StaticResource MutedForeground}" />
            <Label
                x:Name="TrickOutcomeLabel"
                FontSize="13"
                FontAttributes="Bold"
                TextColor="{StaticResource AccentGreen}"
                IsVisible="False" />
            <controls:PlayingCardView Card="{Binding LastPlayedCard}" HorizontalOptions="Start" />
        </VerticalStackLayout>

        <Label
            x:Name="TurnLabel"
            Grid.Row="2"
            FontSize="14"
            FontAttributes="Bold"
            TextColor="{StaticResource AccentGreen}" />

        <controls:KopoBoardView
            x:Name="KopoBoard"
            Grid.Row="3"
            IsVisible="False"
            VerticalOptions="Center"
            HorizontalOptions="Center" />

        <CollectionView
            x:Name="HandView"
            Grid.Row="3"
            ItemsSource="{Binding PlayerCards}"
            VerticalOptions="Fill">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="0" BackgroundColor="Transparent">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnHandCardTapped" />
                        </Border.GestureRecognizers>
                        <controls:PlayingCardView Card="{Binding .}" />
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Label
            x:Name="KopoChainHint"
            Grid.Row="4"
            IsVisible="False"
            FontSize="11"
            TextColor="{StaticResource PrimaryGold}"
            HorizontalTextAlignment="Center" />

        <Button
            x:Name="TakeCardButton"
            Grid.Row="4"
            Clicked="OnTakeCardTapped"
            CornerRadius="12"
            HeightRequest="44"
            BackgroundColor="#3A404D"
            TextColor="{StaticResource Foreground}"
            IsEnabled="False" />

        <Label
            x:Name="TakeCardHintLabel"
            Grid.Row="4"
            Margin="0,50,0,0"
            FontSize="11"
            TextColor="{StaticResource MutedForeground}"
            HorizontalTextAlignment="Center"
            LineBreakMode="WordWrap" />

        <Label x:Name="ErrorLabel" Grid.Row="5" IsVisible="False" TextColor="{StaticResource Destructive}" />
        <ActivityIndicator x:Name="Busy" Grid.Row="5" IsRunning="False" Color="{StaticResource PrimaryGold}" />

        <Border
            x:Name="SendingMoveOverlay"
            Grid.Row="1"
            Grid.RowSpan="4"
            IsVisible="False"
            BackgroundColor="#BF12151f"
            Padding="16"
            StrokeThickness="0">
            <Label
                x:Name="SendingMoveLabel"
                VerticalOptions="Center"
                HorizontalTextAlignment="Center"
                FontSize="14"
                FontAttributes="Bold"
                TextColor="{StaticResource Foreground}" />
        </Border>

        <Border
            x:Name="InactivityOverlay"
            Grid.Row="0"
            Grid.RowSpan="6"
            IsVisible="False"
            BackgroundColor="#CC12151f"
            Padding="20"
            StrokeThickness="0">
            <Border
                VerticalOptions="Center"
                Padding="20"
                BackgroundColor="{StaticResource Card}"
                StrokeShape="RoundRectangle 20">
                <VerticalStackLayout Spacing="14">
                    <Label
                        x:Name="InactivityMessageLabel"
                        FontSize="13"
                        LineBreakMode="WordWrap"
                        HorizontalTextAlignment="Center"
                        TextColor="{StaticResource Foreground}" />
                    <Label
                        x:Name="InactivityCountLabel"
                        FontSize="36"
                        FontAttributes="Bold"
                        HorizontalTextAlignment="Center"
                        TextColor="{StaticResource PrimaryGold}" />
                    <Grid x:Name="InactivityButtonsRow" ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Button
                            x:Name="InactivityContinueBtn"
                            Grid.Column="0"
                            Clicked="OnInactivityContinue"
                            CornerRadius="12"
                            HeightRequest="44"
                            BackgroundColor="#3A404D"
                            TextColor="{StaticResource Foreground}" />
                        <Button
                            x:Name="InactivityCancelBtn"
                            Grid.Column="1"
                            Clicked="OnInactivityCancel"
                            CornerRadius="12"
                            HeightRequest="44"
                            BackgroundColor="#D64545"
                            TextColor="White" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Border>

        <Border
            x:Name="ResultOverlay"
            Grid.Row="0"
            Grid.RowSpan="6"
            IsVisible="{Binding ShowGameResult}"
            BackgroundColor="#CC12151f"
            Padding="24"
            StrokeThickness="0">
            <Border
                VerticalOptions="Center"
                Padding="24"
                BackgroundColor="{StaticResource Card}"
                StrokeShape="RoundRectangle 20">
                <VerticalStackLayout Spacing="12">
                    <Label x:Name="ResultTitle" FontSize="22" FontAttributes="Bold" HorizontalTextAlignment="Center" TextColor="{StaticResource Foreground}" />
                    <Label Text="{Binding WinnerPlayerName}" FontSize="18" HorizontalTextAlignment="Center" TextColor="{StaticResource PrimaryGold}" />
                    <Button x:Name="DoneBtn" Clicked="OnDone" CornerRadius="12" BackgroundColor="{StaticResource PrimaryGold}" TextColor="{StaticResource PrimaryDarkText}" />
                </VerticalStackLayout>
            </Border>
        </Border>
    </Grid>
</ContentPage>
