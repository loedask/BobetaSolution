<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Bobeta.Mobile.Pages.GamePlayPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:Bobeta.Mobile.Controls"
    BackgroundColor="{StaticResource PageBackground}">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Padding="16" RowSpacing="12">
        <Border Grid.Row="0" Padding="14" BackgroundColor="{StaticResource Card}" StrokeShape="RoundRectangle 14">
            <VerticalStackLayout Spacing="8">
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                    <VerticalStackLayout Spacing="2" VerticalOptions="Start">
                        <Label x:Name="PotTableLabel" FontSize="10" TextColor="{StaticResource MutedForeground}" />
                        <Label
                            x:Name="PotTotalLabel"
                            FontSize="22"
                            FontAttributes="Bold"
                            TextColor="{StaticResource PrimaryGold}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout
                        Grid.Column="1"
                        Spacing="4"
                        HorizontalOptions="End"
                        VerticalOptions="Start">
                        <Label x:Name="PotSeatsLabel" FontSize="9" TextColor="{StaticResource MutedForeground}" HorizontalTextAlignment="End" />
                        <Border
                            x:Name="PotOpponentBadge"
                            Padding="8,6"
                            IsVisible="False"
                            HorizontalOptions="End"
                            BackgroundColor="#14EAB308"
                            Stroke="{StaticResource PrimaryGold}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 12">
                            <HorizontalStackLayout Spacing="8" HorizontalOptions="End">
                                <VerticalStackLayout Spacing="0" VerticalOptions="Center" HorizontalOptions="End">
                                    <Label x:Name="PotOpponentLaneLabel" FontSize="8" TextColor="{StaticResource PrimaryGold}" HorizontalTextAlignment="End" />
                                    <Label
                                        x:Name="PotOpponentNameLabel"
                                        FontSize="11"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource Foreground}"
                                        LineBreakMode="TailTruncation"
                                        MaxLines="1"
                                        WidthRequest="118"
                                        HorizontalTextAlignment="End" />
                                </VerticalStackLayout>
                                <Border
                                    WidthRequest="36"
                                    HeightRequest="36"
                                    StrokeShape="RoundRectangle 18"
                                    BackgroundColor="#33EAB308"
                                    Stroke="{StaticResource PrimaryGold}"
                                    StrokeThickness="1"
                                    VerticalOptions="Center">
                                    <Label
                                        x:Name="PotOpponentInitialsLabel"
                                        FontSize="11"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource PrimaryGold}"
                                        HorizontalTextAlignment="Center"
                                        VerticalTextAlignment="Center" />
                                </Border>
                            </HorizontalStackLayout>
                        </Border>
                        <HorizontalStackLayout Spacing="6" HorizontalOptions="End">
                            <Border
                                Padding="10,5"
                                BackgroundColor="#18EAB308"
                                Stroke="{StaticResource PrimaryGold}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 20">
                                <Label x:Name="ChipLeftText" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource PrimaryGold}" />
                            </Border>
                            <Label Text="+" VerticalOptions="Center" TextColor="{StaticResource MutedForeground}" FontAttributes="Bold" />
                            <Border
                                Padding="10,5"
                                BackgroundColor="#18EAB308"
                                Stroke="{StaticResource PrimaryGold}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 20">
                                <Label x:Name="ChipRightText" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource PrimaryGold}" />
                            </Border>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Grid>
                <BoxView HeightRequest="1" Color="#2A2F38" Margin="0,2,0,0" />
                <Label x:Name="PotHintLabel" FontSize="11" TextColor="{StaticResource MutedForeground}" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Border>

        <VerticalStackLayout Grid.Row="1" Spacing="8">
            <Label x:Name="LastPlayTitle" FontSize="12" TextColor="{StaticResource MutedForeground}" />
            <controls:PlayingCardView Card="{Binding LastPlayedCard}" HorizontalOptions="Start" />
        </VerticalStackLayout>

        <Label
            x:Name="TurnLabel"
            Grid.Row="2"
            FontSize="14"
            FontAttributes="Bold"
            TextColor="{StaticResource AccentGreen}" />

        <CollectionView
            x:Name="HandView"
            Grid.Row="3"
            ItemsSource="{Binding PlayerCards}"
            VerticalOptions="Fill">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="0" BackgroundColor="Transparent">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnHandCardTapped" />
                        </Border.GestureRecognizers>
                        <controls:PlayingCardView Card="{Binding .}" />
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Label x:Name="ErrorLabel" Grid.Row="4" IsVisible="False" TextColor="{StaticResource Destructive}" />
        <ActivityIndicator x:Name="Busy" Grid.Row="4" IsRunning="False" Color="{StaticResource PrimaryGold}" />

        <Border
            x:Name="ResultOverlay"
            Grid.Row="0"
            Grid.RowSpan="5"
            IsVisible="{Binding ShowGameResult}"
            BackgroundColor="#CC12151f"
            Padding="24"
            StrokeThickness="0">
            <Border
                VerticalOptions="Center"
                Padding="24"
                BackgroundColor="{StaticResource Card}"
                StrokeShape="RoundRectangle 20">
                <VerticalStackLayout Spacing="12">
                    <Label x:Name="ResultTitle" FontSize="22" FontAttributes="Bold" HorizontalTextAlignment="Center" TextColor="{StaticResource Foreground}" />
                    <Label Text="{Binding WinnerPlayerName}" FontSize="18" HorizontalTextAlignment="Center" TextColor="{StaticResource PrimaryGold}" />
                    <Button x:Name="DoneBtn" Clicked="OnDone" CornerRadius="12" BackgroundColor="{StaticResource PrimaryGold}" TextColor="{StaticResource PrimaryDarkText}" />
                </VerticalStackLayout>
            </Border>
        </Border>
    </Grid>
</ContentPage>
