<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Bobeta.Mobile.Pages.GameHistoryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{StaticResource PageBackground}"
    Title="History">

    <Grid Padding="16">
        <CollectionView ItemsSource="{Binding Rows}">
            <CollectionView.EmptyView>
                <Label x:Name="EmptyLabel" TextColor="{StaticResource MutedForeground}" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,8" Padding="14" BackgroundColor="{StaticResource Card}" StrokeShape="RoundRectangle 12">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                            <VerticalStackLayout Grid.RowSpan="2" Spacing="2">
                                <Label Text="{Binding Title}" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource Foreground}" />
                                <Label
                                    Text="{Binding Subtitle}"
                                    FontSize="11"
                                    TextColor="{StaticResource MutedForeground}"
                                    IsVisible="{Binding HasSubtitle}" />
                                <Label Text="{Binding Time}" FontSize="12" TextColor="{StaticResource MutedForeground}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout
                                Grid.Column="1"
                                Grid.RowSpan="2"
                                Spacing="6"
                                HorizontalOptions="End"
                                VerticalOptions="Center">
                                <Label
                                    Text="{Binding AmountText}"
                                    FontAttributes="Bold"
                                    TextColor="{Binding AmountColor}"
                                    HorizontalTextAlignment="End" />
                                <Button
                                    Text="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ContinueButtonText}"
                                    Padding="10,6"
                                    FontSize="11"
                                    CornerRadius="8"
                                    BackgroundColor="{StaticResource PrimaryGold}"
                                    TextColor="{StaticResource PrimaryDarkText}"
                                    IsVisible="{Binding ShowContinue}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ContinueGameCommand}"
                                    CommandParameter="{Binding SessionId}" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <Label x:Name="ErrorLabel" IsVisible="False" TextColor="{StaticResource Destructive}" VerticalOptions="Start" />
        <ActivityIndicator x:Name="Busy" IsRunning="False" Color="{StaticResource PrimaryGold}" VerticalOptions="Center" HorizontalOptions="Center" />
    </Grid>
</ContentPage>
