<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Bobeta.Mobile.Controls.PlayingCardView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="Root">
    <Border
        x:Name="Chrome"
        Padding="0"
        Stroke="{StaticResource Border}"
        StrokeThickness="1"
        StrokeShape="RoundRectangle 8"
        BackgroundColor="#f3eee6"
        WidthRequest="56"
        HeightRequest="78">
        <Border.Shadow>
            <Shadow Brush="Black" Offset="0,3" Radius="6" Opacity="0.22" />
        </Border.Shadow>
        <Grid>
            <Grid x:Name="FaceGrid" IsVisible="False" Padding="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <VerticalStackLayout
                Grid.Row="0"
                Spacing="0"
                HorizontalOptions="Start"
                VerticalOptions="Start">
                <Label
                    x:Name="CornerRankTop"
                    FontSize="11"
                    FontAttributes="Bold"
                    FontFamily="OpenSansSemibold"
                    TextColor="#0f172a" />
                <Label
                    x:Name="CornerSuitTop"
                    FontSize="9"
                    TextColor="#0f172a"
                    Margin="0,-1,0,0" />
            </VerticalStackLayout>
            <Label
                x:Name="CenterSuit"
                Grid.Row="1"
                FontSize="30"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                TextColor="#0f172a" />
            <VerticalStackLayout
                Grid.Row="2"
                Spacing="0"
                HorizontalOptions="End"
                VerticalOptions="End"
                Rotation="180">
                <Label
                    x:Name="CornerRankBottom"
                    FontSize="11"
                    FontAttributes="Bold"
                    FontFamily="OpenSansSemibold"
                    TextColor="#0f172a" />
                <Label
                    x:Name="CornerSuitBottom"
                    FontSize="9"
                    TextColor="#0f172a"
                    Margin="0,-1,0,0" />
            </VerticalStackLayout>
            </Grid>
            <Label
                x:Name="EmptyLabel"
                Text="—"
                FontSize="22"
                TextColor="{StaticResource MutedForeground}"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                IsVisible="True" />
        </Grid>
    </Border>
</ContentView>
