<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Bobeta.Mobile.Controls.NgolaBoardView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Border Padding="12" BackgroundColor="#78350F" Stroke="#92400E" StrokeShape="RoundRectangle 22">
        <VerticalStackLayout Spacing="10">
            <Grid ColumnDefinitions="*,*">
                <Label x:Name="OpponentScoreLabel" TextColor="#FEF3C7" FontAttributes="Bold" />
                <Label x:Name="MyScoreLabel" Grid.Column="1" TextColor="#FEF3C7" FontAttributes="Bold" HorizontalTextAlignment="End" />
            </Grid>
            <Grid x:Name="BoardGrid" RowDefinitions="Auto,Auto" ColumnSpacing="4" RowSpacing="8" />
        </VerticalStackLayout>
    </Border>
</ContentView>
