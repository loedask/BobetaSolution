<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Bobeta.Mobile.Controls.NzengueBoardView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Border Padding="12" BackgroundColor="#0F172A" Stroke="#334155" StrokeShape="RoundRectangle 22">
        <VerticalStackLayout Spacing="10">
            <Label
                x:Name="PhaseLabel"
                FontSize="12"
                TextColor="#94a3b8"
                HorizontalTextAlignment="Center" />
            <Grid x:Name="BoardGrid" ColumnDefinitions="*,*,*" RowDefinitions="*,*,*" ColumnSpacing="10" RowSpacing="10" />
        </VerticalStackLayout>
    </Border>
</ContentView>
