<li class="lp-step">
    <span class="lp-step__num">@Number</span>
    <div class="lp-step__body">
        <h3>@Title</h3>
        <p>@Description</p>
    </div>
</li>

@code {
    [Parameter, EditorRequired] public string Number { get; set; } = "";
    [Parameter, EditorRequired] public string Title { get; set; } = "";
    [Parameter, EditorRequired] public string Description { get; set; } = "";
}
