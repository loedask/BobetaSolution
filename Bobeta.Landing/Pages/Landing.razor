@page "/"
@layout LandingLayout
@implements IAsyncDisposable
@using Bobeta.Landing.Components
@using Bobeta.Landing.Content
@inject NavigationManager Nav
@inject I18nService I18n
@inject IJSRuntime JS

<header id="lp-header" class="lp-header" aria-label="Bobeta">
    <div class="lp-shell lp-header__row">
        <a href="/" class="lp-mark" aria-label="BOBETA">
            <span>BO</span><span class="lp-mark__be">BE</span><span>TA</span>
        </a>
        <nav class="lp-nav">
            <a href="#features">@I18n.T("landing_nav_features")</a>
            <a href="#games">@I18n.T("landing_nav_games")</a>
            <a href="#how-it-works">@I18n.T("landing_nav_how")</a>
            <a href="#faq">@I18n.T("landing_nav_faq")</a>
            <a href="#get-started">@I18n.T("landing_nav_get_started")</a>
        </nav>
        <div class="lp-header__actions">
            <button type="button" class="lp-btn lp-btn--ghost lp-btn--sm lp-hide-sm" @onclick="GoToLogin">
                @I18n.T("landing_nav_sign_in")
            </button>
            <button type="button" class="lp-btn lp-btn--solid lp-btn--sm" @onclick="GoToStart">
                @I18n.T("landing_cta_play")
            </button>
        </div>
        <div class="lp-header__progress" aria-hidden="true"></div>
    </div>
</header>

<section class="lp-hero">
    <div class="lp-hero__canvas" aria-hidden="true">
        <div class="lp-hero__wash"></div>
        <div class="lp-hero__beam"></div>
        <div class="lp-hero__noise"></div>
        <div class="lp-hero__ring"></div>
        <div class="lp-hero__suits">
            <span>♠</span><span>♥</span><span>♦</span><span>♣</span>
        </div>
        <div class="lp-hero__veil"></div>
    </div>

    <div class="lp-shell lp-hero__content">
        <p class="lp-eyebrow">
            <span class="lp-eyebrow__pulse"></span>
            @I18n.T("secure_momo")
        </p>
        <h1 class="lp-hero__title" aria-label="BOBETA">
            <span class="lp-hero__line lp-hero__line--1"><span>BO</span></span>
            <span class="lp-hero__line lp-hero__line--2"><span class="lp-mark__be">BE</span></span>
            <span class="lp-hero__line lp-hero__line--3"><span>TA</span></span>
        </h1>
        <p class="lp-script lp-hero__script">
            @I18n.T("landing_hero_line1")
            <em>@I18n.T("landing_hero_line2")</em>
        </p>
        <p class="lp-hero__lede">@I18n.T("landing_hero_sub")</p>
        <div class="lp-hero__cta">
            <button type="button" class="lp-btn lp-btn--solid lp-btn--glow" @onclick="GoToStart">
                @I18n.T("landing_cta_play")
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M13 5l7 7-7 7" /></svg>
            </button>
            <a href="#how-it-works" class="lp-btn lp-btn--ghost">@I18n.T("landing_cta_how")</a>
        </div>
    </div>

    <div class="lp-hero__rail" aria-hidden="true">
        <span>@I18n.T("landing_trust_payout")</span>
        <span>@I18n.T("fair_randomized")</span>
        <span>@I18n.T("instant_payouts")</span>
    </div>
</section>

<div class="lp-ticker" aria-hidden="true">
    <div class="lp-ticker__track">
        @for (var i = 0; i < 2; i++)
        {
            <span class="lp-ticker__item">Makopa</span>
            <span class="lp-ticker__sep"></span>
            <span class="lp-ticker__item">Kopo</span>
            <span class="lp-ticker__sep"></span>
            <span class="lp-ticker__item">Ngola</span>
            <span class="lp-ticker__sep"></span>
            <span class="lp-ticker__item">Domino</span>
            <span class="lp-ticker__sep"></span>
            <span class="lp-ticker__item">Abbia</span>
            <span class="lp-ticker__sep"></span>
            <span class="lp-ticker__item">Nzengué</span>
            <span class="lp-ticker__sep"></span>
            <span class="lp-ticker__item">Yoté</span>
            <span class="lp-ticker__sep"></span>
            <span class="lp-ticker__item lp-ticker__item--accent">BOBETA</span>
            <span class="lp-ticker__sep"></span>
            <span class="lp-ticker__item">MoMo</span>
            <span class="lp-ticker__sep"></span>
            <span class="lp-ticker__item">@I18n.T("landing_trust_payout")</span>
            <span class="lp-ticker__sep"></span>
            <span class="lp-ticker__item">@I18n.T("instant_payouts")</span>
            <span class="lp-ticker__sep"></span>
        }
    </div>
</div>

<section id="features" class="lp-manifesto">
    <div class="lp-shell lp-manifesto__grid">
        <div class="lp-manifesto__intro">
            <p class="lp-script lp-script--dark">Bobeta</p>
            <h2>@I18n.T("landing_features_title")</h2>
            <p class="lp-manifesto__sub">@I18n.T("landing_features_sub")</p>
            <div class="lp-manifesto__rule" aria-hidden="true"></div>
        </div>
        <div class="lp-manifesto__list">
            <FeatureCard Icon="shield" Title="@I18n.T("landing_feat_secure_title")" Description="@I18n.T("landing_feat_secure_desc")" Index="01" />
            <FeatureCard Icon="scale" Title="@I18n.T("landing_feat_fair_title")" Description="@I18n.T("landing_feat_fair_desc")" Index="02" />
            <FeatureCard Icon="bolt" Title="@I18n.T("landing_feat_payout_title")" Description="@I18n.T("landing_feat_payout_desc")" Index="03" />
            <FeatureCard Icon="phone" Title="@I18n.T("landing_feat_mobile_title")" Description="@I18n.T("landing_feat_mobile_desc")" Index="04" />
        </div>
    </div>
</section>

<section id="games" class="lp-arena">
    <div class="lp-shell">
        <header class="lp-section-head">
            <p class="lp-script">@I18n.T("landing_nav_games")</p>
            <h2>@I18n.T("landing_games_title")</h2>
            <p>@I18n.T("landing_games_sub")</p>
        </header>

        <div class="lp-reel"
             role="region"
             aria-roledescription="carousel"
             aria-label="@I18n.T("landing_games_title")"
             @onmouseenter="PauseReel"
             @onmouseleave="ResumeReel">
            <div class="lp-reel__chrome">
                <p class="lp-reel__count" aria-live="polite">
                    <span>@((_activeGame + 1).ToString("00"))</span>
                    <span class="lp-reel__count-sep">/</span>
                    <span>@_games.Length.ToString("00")</span>
                </p>
                <div class="lp-reel__arrows">
                    <button type="button" class="lp-reel__arrow" @onclick="PrevGame" aria-label="Previous game">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
                    </button>
                    <button type="button" class="lp-reel__arrow" @onclick="NextGame" aria-label="Next game">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                    </button>
                </div>
            </div>

            <div class="lp-reel__stage">
                @{
                    var game = _games[_activeGame];
                }
                <article @key="game.Id" class="lp-reel__slide is-active">
                    <div class="lp-reel__visual lp-showcase__stage" aria-hidden="true">
                        @if (game.Id == "makopa")
                        {
                            <div class="lp-felt">
                                <div class="lp-fan">
                                    <div class="lp-card lp-card--red lp-fan__1">A♥</div>
                                    <div class="lp-card lp-card--ink lp-fan__2">K♠</div>
                                    <div class="lp-card lp-card--red lp-fan__3">7♦</div>
                                    <div class="lp-card lp-card--ink lp-fan__4">Q♣</div>
                                </div>
                                <p class="lp-felt__label">Makopa</p>
                            </div>
                        }
                        else if (game.Id == "kopo")
                        {
                            <div class="lp-board-wrap">
                                <div class="lp-board">
                                    @for (var row = 0; row < 8; row++)
                                    {
                                        @for (var col = 0; col < 8; col++)
                                        {
                                            var idx = row * 8 + col;
                                            var dark = (row + col) % 2 == 0;
                                            var hasOrange = idx is 9 or 17 or 25 or 33;
                                            var hasWhite = idx is 30 or 38 or 46 or 54;
                                            <div class="lp-board__cell @(dark ? "is-dark" : "is-light")">
                                                @if (hasOrange)
                                                {
                                                    <span class="lp-piece lp-piece--orange"></span>
                                                }
                                                else if (hasWhite)
                                                {
                                                    <span class="lp-piece lp-piece--white"></span>
                                                }
                                            </div>
                                        }
                                    }
                                </div>
                                <p class="lp-felt__label">Kopo</p>
                            </div>
                        }
                        else if (game.Id == "ngola")
                        {
                            <div class="lp-ngola-wrap">
                                <div class="lp-ngola">
                                    @for (var pit = 0; pit < 16; pit++)
                                    {
                                        <span class="lp-ngola__pit"></span>
                                    }
                                </div>
                                <p class="lp-felt__label">Ngola</p>
                            </div>
                        }
                        else if (game.Id == "domino")
                        {
                            <div class="lp-domino-wrap">
                                <div class="lp-domino">
                                    <span class="lp-domino__tile"><span>6</span><span>6</span></span>
                                    <span class="lp-domino__tile"><span>6</span><span>3</span></span>
                                    <span class="lp-domino__tile"><span>3</span><span>1</span></span>
                                </div>
                                <p class="lp-felt__label">Domino</p>
                            </div>
                        }
                        else if (game.Id == "abbia")
                        {
                            <div class="lp-abbia-wrap">
                                <div class="lp-abbia">
                                    <span class="lp-abbia__token lp-abbia__token--carved"></span>
                                    <span class="lp-abbia__token"></span>
                                    <span class="lp-abbia__token lp-abbia__token--carved"></span>
                                    <span class="lp-abbia__token"></span>
                                    <span class="lp-abbia__token lp-abbia__token--carved"></span>
                                </div>
                                <p class="lp-felt__label">Abbia</p>
                            </div>
                        }
                        else if (game.Id == "nzengue")
                        {
                            <div class="lp-nzengue-wrap">
                                <div class="lp-nzengue" aria-hidden="true">
                                    @for (var point = 0; point < 9; point++)
                                    {
                                        var occupied = point is 0 or 4 or 8;
                                        <span class="lp-nzengue__point@(occupied ? " lp-nzengue__point--mine" : "")"></span>
                                    }
                                </div>
                                <p class="lp-felt__label">Nzengué</p>
                            </div>
                        }
                        else if (game.Id == "yote")
                        {
                            <div class="lp-yote-wrap">
                                <div class="lp-yote" aria-hidden="true">
                                    @for (var cell = 0; cell < 30; cell++)
                                    {
                                        var occupied = cell is 7 or 14 or 22;
                                        <span class="lp-yote__cell@(occupied ? " lp-yote__cell--mine" : "")"></span>
                                    }
                                </div>
                                <p class="lp-felt__label">Yoté</p>
                            </div>
                        }
                    </div>
                    <div class="lp-reel__copy lp-showcase__copy">
                        <span class="lp-showcase__num">@((_activeGame + 1).ToString("00"))</span>
                        <h3>@I18n.T(game.TitleKey)</h3>
                        <p>@I18n.T(game.DescKey)</p>
                        <div class="lp-reel__actions">
                            <button type="button" class="lp-link" @onclick="GoToStart">
                                @I18n.T("landing_cta_play")
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M13 5l7 7-7 7" /></svg>
                            </button>
                            <button type="button" class="lp-link lp-link--quiet" @onclick="() => OpenHistory(game.Id)">
                                @I18n.T("landing_game_history")
                            </button>
                        </div>
                    </div>
                </article>

                <div class="lp-reel__autoplay" aria-hidden="true">
                    <span class="lp-reel__autoplay-bar @(_reelPaused ? "is-paused" : null)" @key="_autoplayEpoch"></span>
                </div>
            </div>

            <div class="lp-reel__thumbs" role="tablist" aria-label="@I18n.T("landing_nav_games")">
                @for (var i = 0; i < _games.Length; i++)
                {
                    var index = i;
                    var thumb = _games[index];
                    var selected = index == _activeGame;
                    <button type="button"
                            class="lp-reel__thumb @(selected ? "is-active" : null)"
                            role="tab"
                            aria-selected="@selected"
                            id="@($"game-tab-{thumb.Id}")"
                            @onclick="() => SelectGame(index)">
                        <span class="lp-reel__thumb-num">@((index + 1).ToString("00"))</span>
                        <span class="lp-reel__thumb-name">@I18n.T(thumb.TitleKey)</span>
                        @if (selected && !_reelPaused)
                        {
                            <span class="lp-reel__thumb-pulse" aria-hidden="true"></span>
                        }
                    </button>
                }
            </div>
        </div>
    </div>
</section>

<section id="how-it-works" class="lp-path">
    <div class="lp-shell">
        <header class="lp-section-head">
            <p class="lp-script">@I18n.T("landing_nav_how")</p>
            <h2>@I18n.T("landing_how_title")</h2>
            <p>@I18n.T("landing_how_sub")</p>
        </header>
        <ol class="lp-path__list">
            <StepCard Number="1" Title="@I18n.T("landing_step1_title")" Description="@I18n.T("landing_step1_desc")" />
            <StepCard Number="2" Title="@I18n.T("landing_step2_title")" Description="@I18n.T("landing_step2_desc")" />
            <StepCard Number="3" Title="@I18n.T("landing_step3_title")" Description="@I18n.T("landing_step3_desc")" />
            <StepCard Number="4" Title="@I18n.T("landing_step4_title")" Description="@I18n.T("landing_step4_desc")" />
        </ol>
    </div>
</section>

<section id="faq" class="lp-help">
    <div class="lp-shell lp-help__grid">
        <div class="lp-help__intro">
            <p class="lp-script">@I18n.T("landing_nav_faq")</p>
            <h2>@I18n.T("landing_faq_title")</h2>
            <p>@I18n.T("landing_faq_sub")</p>
            <a href="/faq" class="lp-link">
                @I18n.T("landing_faq_all")
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M13 5l7 7-7 7" /></svg>
            </a>
        </div>
        <div class="lp-faq">
            @foreach (var item in HelpCopy.Faq(I18n.Locale).Take(4))
            {
                <FaqItem Question="@item.Question" Answer="@item.Answer" />
            }
        </div>
    </div>
</section>

<section id="get-started" class="lp-finale">
    <div class="lp-finale__wash" aria-hidden="true"></div>
    <div class="lp-finale__type" aria-hidden="true">
        <span>BO</span><span class="lp-mark__be">BE</span><span>TA</span>
    </div>
    <div class="lp-shell lp-finale__panel">
        <p class="lp-script">@I18n.T("landing_hero_line1") @I18n.T("landing_hero_line2")</p>
        <h2>@I18n.T("landing_cta_bottom_title")</h2>
        <p class="lp-finale__sub">@I18n.T("landing_cta_bottom_sub")</p>
        <ul class="lp-finale__trust">
            <li>@I18n.T("landing_trust_payout")</li>
            <li>@I18n.T("landing_trust_languages")</li>
            <li>@I18n.T("secure_momo")</li>
        </ul>
        <div class="lp-finale__lang">
            <LanguageSelector />
        </div>
        <button type="button" class="lp-btn lp-btn--solid lp-btn--lg lp-btn--glow" @onclick="GoToStart">
            @I18n.T("get_started")
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M13 5l7 7-7 7" /></svg>
        </button>
    </div>
</section>

<footer class="lp-footer">
    <div class="lp-shell lp-footer__grid">
        <div class="lp-footer__brand">
            <p class="lp-mark lp-mark--sm">
                <span>BO</span><span class="lp-mark__be">BE</span><span>TA</span>
            </p>
            <p class="lp-script lp-script--sm">@I18n.T("landing_hero_line1") @I18n.T("landing_hero_line2")</p>
            <p class="lp-footer__copy">© @DateTime.UtcNow.Year Bobeta. @I18n.T("landing_footer_rights")</p>
        </div>
        <div class="lp-footer__col">
            <p class="lp-footer__label">@I18n.T("landing_footer_help")</p>
            <a href="/what-is-bobeta">@I18n.T("landing_nav_what_is")</a>
            <a href="#faq">@I18n.T("landing_nav_faq")</a>
            <a href="/faq">@I18n.T("landing_faq_all")</a>
            <a href="/rules">@I18n.T("landing_nav_rules")</a>
        </div>
        <div class="lp-footer__col">
            <p class="lp-footer__label">@I18n.T("landing_legal_title")</p>
            <a href="/terms">@I18n.T("landing_nav_terms")</a>
            <a href="/responsible-play">@I18n.T("landing_nav_responsible")</a>
            <a href="/privacy">@I18n.T("landing_nav_privacy")</a>
            <a href="/rules">@I18n.T("landing_nav_rules")</a>
        </div>
    </div>
</footer>

@if (_historyEntry is not null)
{
    <GameHistoryModal Entry="_historyEntry" OnClose="CloseHistory" />
}

@code {
    private static readonly GameSlide[] _games =
    [
        new("makopa", "landing_game_makopa_title", "landing_game_makopa_desc"),
        new("kopo", "landing_game_kopo_title", "landing_game_kopo_desc"),
        new("ngola", "landing_game_ngola_title", "landing_game_ngola_desc"),
        new("domino", "landing_game_domino_title", "landing_game_domino_desc"),
        new("abbia", "landing_game_abbia_title", "landing_game_abbia_desc"),
        new("nzengue", "landing_game_nzengue_title", "landing_game_nzengue_desc"),
        new("yote", "landing_game_yote_title", "landing_game_yote_desc"),
    ];

    private bool _headerBound;
    private int _activeGame;
    private int _autoplayEpoch;
    private bool _reelPaused;
    private CancellationTokenSource? _autoplayCts;
    private GameHistoryCopy.Entry? _historyEntry;

    protected override void OnInitialized() => StartAutoplay();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _headerBound)
            return;

        _headerBound = true;
        await JS.InvokeVoidAsync("bobeta.bindLandingHeader", "lp-header");
    }

    public async ValueTask DisposeAsync()
    {
        StopAutoplay();

        if (!_headerBound)
            return;

        try
        {
            await JS.InvokeVoidAsync("bobeta.clearLandingHeader");
        }
        catch (JSDisconnectedException)
        {
            // Circuit/WASM tearing down — nothing to clear.
        }
    }

    private void SelectGame(int index)
    {
        if (index < 0 || index >= _games.Length || index == _activeGame)
            return;

        _activeGame = index;
        RestartAutoplay();
    }

    private void NextGame()
    {
        _activeGame = (_activeGame + 1) % _games.Length;
        RestartAutoplay();
    }

    private void PrevGame()
    {
        _activeGame = (_activeGame - 1 + _games.Length) % _games.Length;
        RestartAutoplay();
    }

    private void PauseReel()
    {
        _reelPaused = true;
        StopAutoplay();
    }

    private void ResumeReel()
    {
        _reelPaused = false;
        StartAutoplay();
    }

    private void RestartAutoplay()
    {
        _autoplayEpoch++;
        if (!_reelPaused)
            StartAutoplay();
    }

    private void StartAutoplay()
    {
        StopAutoplay();
        if (_games.Length < 2)
            return;

        _autoplayCts = new CancellationTokenSource();
        var token = _autoplayCts.Token;
        _ = RunAutoplayAsync(token);
    }

    private void StopAutoplay()
    {
        if (_autoplayCts is null)
            return;

        _autoplayCts.Cancel();
        _autoplayCts.Dispose();
        _autoplayCts = null;
    }

    private async Task RunAutoplayAsync(CancellationToken token)
    {
        try
        {
            while (!token.IsCancellationRequested)
            {
                await Task.Delay(TimeSpan.FromSeconds(5.5), token);
                await InvokeAsync(() =>
                {
                    _activeGame = (_activeGame + 1) % _games.Length;
                    _autoplayEpoch++;
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException)
        {
            // Expected when pausing, selecting, or disposing.
        }
    }

    private void GoToStart() => Nav.NavigateTo("/start");
    private void GoToLogin() => Nav.NavigateTo("/login");

    private void OpenHistory(string gameId)
    {
        _historyEntry = GameHistoryCopy.For(gameId, I18n.Locale);
        if (_historyEntry is null)
            return;
        PauseReel();
    }

    private void CloseHistory()
    {
        _historyEntry = null;
        ResumeReel();
    }

    private sealed record GameSlide(string Id, string TitleKey, string DescKey);
}
