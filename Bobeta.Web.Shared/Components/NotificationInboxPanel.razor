@inject NotificationInboxViewModel Inbox
@inject I18nService I18n
@implements IDisposable

@if (Inbox.IsOpen)
{
    <div class="fixed inset-0 z-50 flex items-end justify-center bg-background/80 backdrop-blur-sm sm:items-center sm:px-6"
         @onclick="Inbox.Close">
        <div class="card-surface flex max-h-[80vh] w-full max-w-md flex-col rounded-t-2xl border border-border/60 shadow-2xl sm:rounded-2xl"
             @onclick:stopPropagation="true">
            <div class="flex items-center justify-between border-b border-border/40 px-5 py-4">
                <div>
                    <h2 class="font-display text-base font-bold text-foreground">@I18n.T("notifications")</h2>
                    @if (Inbox.UnreadCount > 0)
                    {
                        <p class="text-xs text-muted-foreground">@string.Format(I18n.T("notif_unread_count"), Inbox.UnreadCount)</p>
                    }
                </div>
                <div class="flex items-center gap-2">
                    @if (Inbox.UnreadCount > 0)
                    {
                        <button type="button"
                                class="rounded-lg px-2 py-1 text-xs font-semibold text-primary hover:bg-primary/10"
                                @onclick="Inbox.MarkAllReadAsync">
                            @I18n.T("notif_mark_all_read")
                        </button>
                    }
                    <button type="button"
                            class="flex h-8 w-8 items-center justify-center rounded-lg bg-card text-muted-foreground hover:text-foreground"
                            @onclick="Inbox.Close"
                            aria-label="@I18n.T("cancel")">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                    </button>
                </div>
            </div>

            <div class="overflow-y-auto px-3 py-3">
                <ErrorBanner Message="@Inbox.ErrorMessage" />
                @if (Inbox.IsLoading && Inbox.Items.Count == 0)
                {
                    <div class="space-y-2">
                        @for (var i = 0; i < 3; i++)
                        {
                            <SkeletonLoader CssClass="h-16 rounded-xl" />
                        }
                    </div>
                }
                else if (Inbox.Items.Count == 0)
                {
                    <div class="flex flex-col items-center gap-2 py-10 text-center">
                        <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-muted/30">
                            <svg class="h-6 w-6 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" /></svg>
                        </div>
                        <p class="text-sm font-medium text-foreground">@I18n.T("notif_empty_title")</p>
                        <p class="text-xs text-muted-foreground">@I18n.T("notif_empty_body")</p>
                    </div>
                }
                else
                {
                    <div class="space-y-2">
                        @foreach (var item in Inbox.Items)
                        {
                            <button type="button"
                                    class="@(item.IsRead ? "bg-card/40" : "bg-primary/5 border-primary/20") flex w-full items-start gap-3 rounded-xl border border-border/40 px-3 py-3 text-left transition-colors hover:bg-secondary/40"
                                    @onclick="() => Inbox.OpenItemAsync(item)">
                                <div class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-secondary">
                                    @if (!item.IsRead)
                                    {
                                        <span class="h-2 w-2 rounded-full bg-accent"></span>
                                    }
                                    else
                                    {
                                        <span class="h-2 w-2 rounded-full bg-muted-foreground/40"></span>
                                    }
                                </div>
                                <div class="min-w-0 flex-1">
                                    <p class="font-display text-sm font-semibold text-foreground">@Inbox.TitleFor(item)</p>
                                    <p class="mt-0.5 text-xs leading-relaxed text-muted-foreground">@Inbox.BodyFor(item)</p>
                                    <p class="mt-1 text-[11px] text-muted-foreground/80">@item.CreatedAt.ToLocalTime().ToString("g")</p>
                                </div>
                            </button>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    protected override void OnInitialized() => Inbox.StateChanged += OnChanged;
    public void Dispose() => Inbox.StateChanged -= OnChanged;
    private void OnChanged() => InvokeAsync(StateHasChanged);
}
