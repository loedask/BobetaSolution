@namespace Bobeta.Web.Shared.Components
@inject I18nService I18n

@if (HasPendingCode)
{
    <div class="rounded-2xl border border-primary/30 bg-primary/10 px-4 py-3 text-sm text-foreground">
        <p class="font-medium">@PendingTitle</p>
        @if (!string.IsNullOrEmpty(PendingDetail))
        {
            <p class="mt-1 text-xs text-muted-foreground">@PendingDetail</p>
        }
    </div>
}
else
{
    <div class="rounded-2xl border border-border/50 bg-card/60 px-4 py-3">
        <p class="font-display text-sm font-semibold text-foreground">@I18n.T("invite_have_code")</p>
        <p class="mt-1 text-xs text-muted-foreground">@I18n.T("invite_enter_hint")</p>
        @if (!string.IsNullOrEmpty(SuccessMessage))
        {
            <p class="mt-2 text-xs text-accent">@SuccessMessage</p>
        }
        <div class="mt-3 flex gap-2">
            <input class="flex-1 rounded-xl border border-border/60 bg-background/40 px-3 py-2.5 text-sm text-foreground outline-none focus:border-primary/50"
                   placeholder="@I18n.T("invite_enter_code")"
                   value="@CodeInput"
                   @oninput="OnInput"
                   disabled="@Disabled" />
            <button type="button"
                    class="rounded-xl bg-primary/15 px-4 py-2.5 text-sm font-semibold text-primary disabled:opacity-50"
                    disabled="@(Disabled || string.IsNullOrWhiteSpace(CodeInput))"
                    @onclick="HandleApplyAsync">
                @I18n.T("invite_apply")
            </button>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool HasPendingCode { get; set; }

    [Parameter]
    public string PendingTitle { get; set; } = "";

    [Parameter]
    public string? PendingDetail { get; set; }

    [Parameter]
    public string CodeInput { get; set; } = "";

    [Parameter]
    public EventCallback<string> CodeInputChanged { get; set; }

    [Parameter]
    public EventCallback OnApply { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public string? SuccessMessage { get; set; }

    private async Task OnInput(ChangeEventArgs e)
    {
        CodeInput = e.Value?.ToString() ?? "";
        await CodeInputChanged.InvokeAsync(CodeInput);
    }

    private Task HandleApplyAsync() => OnApply.InvokeAsync();
}
