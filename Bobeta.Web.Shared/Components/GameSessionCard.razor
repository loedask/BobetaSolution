@using Bobeta.Client.Models.Api
@inject I18nService I18n

<div class="flex items-center justify-between gap-3 rounded-2xl border border-border/50 bg-background/30 p-3.5 transition-colors hover:border-primary/25 hover:bg-primary/[0.03]">
    <div class="flex min-w-0 items-center gap-3">
        <div class="relative flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-secondary/80 ring-1 ring-border/60">
            <svg class="h-5 w-5 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
            <span class="absolute -bottom-1 -right-1 h-2.5 w-2.5 rounded-full border-2 border-card bg-accent"></span>
        </div>
        <div class="min-w-0">
            <div class="flex flex-wrap items-center gap-2">
                <span class="truncate font-display text-sm font-semibold text-foreground">@PlayerName</span>
                <span class="rounded-md bg-primary/15 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-primary">@GameVariantLabels.Name(Variant)</span>
            </div>
            <p class="mt-0.5 text-xs text-muted-foreground">@I18n.T("waiting_for_opponent_short")</p>
        </div>
    </div>
    <div class="flex shrink-0 items-center gap-3">
        <div class="text-right">
            <div class="gold-text font-display text-lg font-bold leading-none">@BetAmount.ToString("N0")</div>
            <div class="mt-0.5 text-[10px] font-medium uppercase tracking-wide text-muted-foreground">FCFA</div>
        </div>
        <button type="button" class="gold-gradient inline-flex items-center justify-center rounded-xl px-3.5 py-2.5 text-xs font-semibold text-primary-foreground shadow transition-all active:scale-95" @onclick="OnJoin">@I18n.T("join")</button>
    </div>
</div>

@code {
    [Parameter] public string PlayerName { get; set; } = "";
    [Parameter] public decimal BetAmount { get; set; }
    [Parameter] public GameVariant Variant { get; set; } = GameVariant.Makopa;
    [Parameter] public EventCallback OnJoin { get; set; }
}
