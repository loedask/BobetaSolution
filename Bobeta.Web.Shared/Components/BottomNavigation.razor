@inject NavigationManager Nav
@inject I18nService I18n
@implements IDisposable

@{
    // ToBaseRelativePath avoids BaseUri string mismatches (trailing slash, casing) that left the wrong segment and highlighted the wrong tab.
    var relative = Nav.ToBaseRelativePath(Nav.Uri);
    var q = relative.IndexOf('?', StringComparison.Ordinal);
    if (q >= 0) relative = relative[..q];
    var hash = relative.IndexOf('#', StringComparison.Ordinal);
    if (hash >= 0) relative = relative[..hash];
    var path = relative.Split('/', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? "";
    var hide = path is "" or "login" or "verify" or "create-player" or "invite";
}

@if (!hide)
{
    <nav class="fixed bottom-0 left-0 right-0 z-50 border-t border-border bg-card/95 backdrop-blur-xl safe-area-pb">
        <div class="mx-auto flex max-w-lg items-center justify-around px-2 py-2">
            <a href="/dashboard" class="flex flex-col items-center gap-0.5 rounded-xl px-3 py-1.5 text-xs font-medium transition-all @(path == "dashboard" ? "text-primary" : "text-muted-foreground")">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
                <span>@I18n.T("home")</span>
            </a>
            <a href="/create-game" class="flex flex-col items-center gap-0.5 rounded-xl px-3 py-1.5 text-xs font-medium transition-all @(path == "create-game" ? "text-primary" : "text-muted-foreground")">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                <span>@I18n.T("create")</span>
            </a>
            <a href="/join" class="flex flex-col items-center gap-0.5 rounded-xl px-3 py-1.5 text-xs font-medium transition-all @(path == "join" ? "text-primary" : "text-muted-foreground")">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
                <span>@I18n.T("join_game")</span>
            </a>
            <a href="/history" class="flex flex-col items-center gap-0.5 rounded-xl px-3 py-1.5 text-xs font-medium transition-all @(path == "history" ? "text-primary" : "text-muted-foreground")">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                <span>@I18n.T("history")</span>
            </a>
            <a href="/profile" class="flex flex-col items-center gap-0.5 rounded-xl px-3 py-1.5 text-xs font-medium transition-all @(path == "profile" ? "text-primary" : "text-muted-foreground")">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                <span>@I18n.T("profile")</span>
            </a>
        </div>
    </nav>
}

@code {
    protected override void OnInitialized() => Nav.LocationChanged += OnLocationChanged;

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e) =>
        _ = InvokeAsync(StateHasChanged);

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;
}
