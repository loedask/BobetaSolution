@inject I18nService I18n

<div class="flex items-center justify-between rounded-xl bg-card p-3.5">
    <div class="flex items-center gap-3">
        <div class="flex h-9 w-9 items-center justify-center rounded-lg @IconBgClass">
            @if (IsWin)
            {
                <svg class="h-4 w-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
            }
            else if (IsDeposit)
            {
                <svg class="h-4 w-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
            }
            else
            {
                <svg class="h-4 w-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" /></svg>
            }
        </div>
        <div>
            <div class="text-sm font-semibold text-foreground">@Description</div>
            <div class="text-xs text-muted-foreground">@Time</div>
        </div>
    </div>
    <div class="font-display font-bold @(Amount >= 0 ? "text-accent" : "text-muted-foreground")">
        @(Amount >= 0 ? "+" : "")@Amount.ToString("N0") FCFA
    </div>
</div>

@code {
    [Parameter] public string Description { get; set; } = "";
    [Parameter] public string Time { get; set; } = "";
    [Parameter] public decimal Amount { get; set; }
    private bool IsWin => Amount > 0 && !IsDeposit;
    private bool IsDeposit => Description == I18n.T("deposit_label");
    private string IconBgClass => IsWin ? "bg-accent/10" : IsDeposit ? "bg-primary/10" : "bg-secondary";
}
