@inherits LayoutComponentBase
@implements IDisposable
@inject AppStateService AppState
@inject NotificationInboxViewModel Inbox

<div class="mx-auto max-w-lg min-h-screen bg-background flex flex-col">
    @Body
    <BottomNavigation />
</div>

@code {
    protected override void OnInitialized() => AppState.StateChanged += OnStateChanged;

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrWhiteSpace(AppState.State.AccessToken))
            await Inbox.InitializeAsync();
    }

    private void OnStateChanged() => _ = InvokeAsync(StateHasChanged);

    public void Dispose() => AppState.StateChanged -= OnStateChanged;
}
