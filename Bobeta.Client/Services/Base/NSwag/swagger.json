    "/api/Auth/send-otp": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Sends a one-time password (OTP) by SMS to the phone number for phone-based sign-in.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Bobeta.Application.DTOs.Auth.SendOtpRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/Bobeta.Application.DTOs.Auth.SendOtpRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/Bobeta.Application.DTOs.Auth.SendOtpRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Auth/verify-otp": {
      "post": {
