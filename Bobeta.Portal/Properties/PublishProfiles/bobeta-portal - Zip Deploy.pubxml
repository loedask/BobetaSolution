<?xml version="1.0" encoding="utf-8"?>
<!--
Publish Bobeta.Portal to Azure Linux App Service (Blazor Server — requires WebSockets).
Create the app as Linux + .NET 10, then set ResourceId/PublishUrl to your site (see docs/DEPLOYMENT.md).
-->
<Project>
  <PropertyGroup>
    <WebPublishMethod>ZipDeploy</WebPublishMethod>
    <IsLinux>true</IsLinux>
    <RuntimeIdentifier>linux-x64</RuntimeIdentifier>
    <SelfContained>false</SelfContained>
    <ResourceId>/subscriptions/0e683e4e-5f71-4426-92ad-59d3d7d90f32/resourceGroups/bobeta_group/providers/Microsoft.Web/sites/bobeta-portal</ResourceId>
    <ResourceGroup>bobeta_group</ResourceGroup>
    <LaunchSiteAfterPublish>true</LaunchSiteAfterPublish>
    <SiteUrlToLaunchAfterPublish>https://bobeta-portal.azurewebsites.net</SiteUrlToLaunchAfterPublish>
    <PublishProvider>AzureWebSite</PublishProvider>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>
    <PublishUrl>https://bobeta-portal.scm.azurewebsites.net/</PublishUrl>
    <UserName />
    <_SavePWD>false</_SavePWD>
  </PropertyGroup>
</Project>
