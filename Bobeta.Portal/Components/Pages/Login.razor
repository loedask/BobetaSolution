@page "/login"
@layout Bobeta.Portal.Components.Layout.LoginLayout
@attribute [AllowAnonymous]

<PageTitle>Sign in - Bobeta Portal</PageTitle>

<div class="portal-login-card">
    <h1>Bobeta Portal</h1>
    <p class="portal-muted">Sign in with your employee account.</p>

    @if (Error == "invalid")
    {
        <div class="portal-alert portal-alert-error">Invalid email or password.</div>
    }

    <form method="post" action="/account/login">
        <AntiforgeryToken />
        <input type="hidden" name="returnUrl" value="@ReturnUrl" />
        <div class="portal-field">
            <label for="email">Email</label>
            <input id="email" name="email" class="portal-input" type="email" autocomplete="username" required />
        </div>
        <div class="portal-field">
            <label for="password">Password</label>
            <input id="password" name="password" type="password" class="portal-input" autocomplete="current-password" required />
        </div>
        <button class="portal-button portal-button-primary" type="submit">Sign in</button>
    </form>
</div>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery]
    public string? Error { get; set; }
}
