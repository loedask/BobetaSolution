@page "/my-influencer"
@attribute [Authorize(Roles = "Influencer")]
@inject IInfluencerService InfluencerService
@inject AuthenticationStateProvider AuthState
@inject Microsoft.Extensions.Options.IOptions<Bobeta.Application.Configuration.PortalSettings> PortalOptions
@rendermode InteractiveServer

<PageTitle>My influencer - Bobeta Portal</PageTitle>

<div class="portal-page-header">
    <div>
        <h1>My influencer</h1>
        <p class="portal-muted">Your invite code and commission rate.</p>
    </div>
    <a class="portal-button portal-button-primary" href="/my-influencer/revenue">Revenue report</a>
</div>

@if (_loading)
{
    <p class="portal-muted">Loading...</p>
}
else if (_influencer is null)
{
    <div class="portal-alert portal-alert-error">No influencer profile linked to your account.</div>
}
else
{
    <section class="portal-card portal-section">
        <dl class="portal-dl">
            <div><dt>Display name</dt><dd>@_influencer.DisplayName</dd></div>
            <div><dt>Invite code</dt><dd><code>@_influencer.Code</code></dd></div>
            <div><dt>Invite link</dt><dd><CopyableText Text="@InviteUrl" /></dd></div>
            <div><dt>Your commission</dt><dd>@_influencer.CommissionPercent.ToString("N2")% of half the game platform fee per player who used your code</dd></div>
        </dl>
        <p class="portal-muted">Player discount is set by the platform owner and applied when a player uses your code on a game.</p>
    </section>
}

@code {
    private InfluencerListItemDto? _influencer;
    private bool _loading = true;

    private string InviteUrl =>
        $"{PortalOptions.Value.PlayerWebBaseUrl.TrimEnd('/')}/invite/{_influencer!.Code}";

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        var userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (userId is not null && Guid.TryParse(userId, out var portalUserId))
            _influencer = await InfluencerService.GetByPortalUserIdAsync(portalUserId);

        _loading = false;
    }
}
