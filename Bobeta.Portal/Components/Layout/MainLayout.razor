@inherits LayoutComponentBase

<div class="portal-shell">
    <aside class="portal-sidebar">
        <div class="portal-brand">
            <span class="portal-brand-mark">B</span>
            <div>
                <div class="portal-brand-title"><span class="be">Bo</span>beta</div>
                <div class="portal-brand-subtitle">Portal</div>
            </div>
        </div>
        <NavMenu />
    </aside>
    <div class="portal-main">
        <header class="portal-header">
            <AuthorizeView>
                <Authorized>
                    @{
                        var name = context.User.Identity?.Name ?? "User";
                        var initial = string.IsNullOrWhiteSpace(name)
                            ? 'U'
                            : char.ToUpperInvariant(name.Trim()[0]);
                    }
                    <div class="portal-user-chip">
                        <span class="portal-user-avatar">@initial</span>
                        <span class="portal-user">@name</span>
                    </div>
                    <a class="portal-link-button" href="/account/logout">Sign out</a>
                </Authorized>
            </AuthorizeView>
        </header>
        <main class="portal-content">
            @Body
        </main>
    </div>
</div>
