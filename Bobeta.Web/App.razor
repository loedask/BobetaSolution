@using System.Reflection
@using Microsoft.AspNetCore.Components.WebAssembly.Services
@inject LazyAssemblyLoader LazyAssemblyLoader

<ErrorBoundary>
    <ChildContent>
        <Bootstrap>
            <Router AppAssembly="@typeof(App).Assembly"
                    AdditionalAssemblies="@_lazyAssemblies"
                    OnNavigateAsync="OnNavigateAsync"
                    NotFoundPage="typeof(Pages.NotFound)">
                <Found Context="routeData">
                    <RouteView RouteData="@routeData" DefaultLayout="@typeof(Bobeta.Web.Shared.Layout.MainLayout)" />
                </Found>
            </Router>
        </Bootstrap>
    </ChildContent>
    <ErrorContent>
        <div class="min-h-screen bg-background flex items-center justify-center p-6">
            <div class="rounded-2xl border border-border bg-card p-6 text-center max-w-sm">
                <p class="text-destructive font-semibold mb-2">Something went wrong.</p>
                <p class="text-sm text-muted-foreground mb-4">The app encountered an error. Please try again or return home.</p>
                <a href="/" class="text-primary font-medium hover:underline">Return to Home</a>
            </div>
        </div>
    </ErrorContent>
</ErrorBoundary>

@code {
    private readonly List<Assembly> _lazyAssemblies = new();

    private async Task OnNavigateAsync(NavigationContext context)
    {
        if (!LazyRouteHelper.IsDeferredRoute(context.Path))
            return;
        if (_lazyAssemblies.Any(a => string.Equals(a.GetName()?.Name, "Bobeta.Web.Deferred", StringComparison.Ordinal)))
            return;

        var loaded = await LazyAssemblyLoader.LoadAssembliesAsync(new[] { LazyRouteHelper.DeferredAssemblyFileName });
        _lazyAssemblies.AddRange(loaded);
    }
}
