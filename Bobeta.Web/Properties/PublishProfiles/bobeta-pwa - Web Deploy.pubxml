<?xml version="1.0" encoding="utf-8"?>
<!--
Legacy Windows/IIS publish — deprecated. Use Bobeta.Web.Host with "bobeta-pwa - Zip Deploy" (Linux) instead. See docs/DEPLOYMENT.md.
-->
<Project>
  <PropertyGroup>
    <WebPublishMethod>MSDeploy</WebPublishMethod>
    <ResourceId>/subscriptions/0e683e4e-5f71-4426-92ad-59d3d7d90f32/resourceGroups/bobeta_group/providers/Microsoft.Web/sites/bobeta-pwa</ResourceId>
    <ResourceGroup>bobeta_group</ResourceGroup>
    <PublishProvider>AzureWebSite</PublishProvider>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>
    <SiteUrlToLaunchAfterPublish>https://bobeta-pwa.azurewebsites.net</SiteUrlToLaunchAfterPublish>
    <LaunchSiteAfterPublish>true</LaunchSiteAfterPublish>
    <ExcludeApp_Data>false</ExcludeApp_Data>
    <ProjectGuid>a057a7e4-b731-e250-d850-1280f29820a3</ProjectGuid>
    <MSDeployServiceURL>bobeta-pwa.scm.azurewebsites.net:443</MSDeployServiceURL>
    <DeployIisAppPath>bobeta-pwa</DeployIisAppPath>
    <RemoteSitePhysicalPath />
    <SkipExtraFilesOnServer>true</SkipExtraFilesOnServer>
    <MSDeployPublishMethod>WMSVC</MSDeployPublishMethod>
    <EnableMSDeployBackup>true</EnableMSDeployBackup>
    <EnableMsDeployAppOffline>true</EnableMsDeployAppOffline>
    <UserName />
    <_SavePWD>false</_SavePWD>
    <_DestinationType>AzureWebSite</_DestinationType>
    <InstallAspNetCoreSiteExtension>false</InstallAspNetCoreSiteExtension>
  </PropertyGroup>
</Project>