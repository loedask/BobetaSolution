@page "/game/{SessionId}"
@layout MainLayout
@using Bobeta.Web.Components.Game
@using Bobeta.Web.Services.Realtime
@inject GamePlayService GamePlayService
@inject IGameService GameService
@inject AppStateService AppState
@inject NavigationManager Nav
@inject GameHubClient GameHubClient
@inject GamePlayTestService GamePlayTestService
@inject I18nService I18n
@implements IAsyncDisposable

<div class="min-h-screen bg-background pb-24">
    <AppHeader Title="Game" ShowBack="true" BackHref="/dashboard" />

    <div class="space-y-4 px-5 py-4">
        <ErrorBanner Message="@ViewModel.ErrorMessage" />

        @if (ViewModel.IsLoading && ViewModel.PlayerCards.Count == 0)
        {
            <SkeletonLoader CssClass="h-12 rounded-xl mb-4" />
            <SkeletonLoader CssClass="h-24 rounded-2xl mb-4" />
            <SkeletonLoader CssClass="h-32 rounded-2xl mb-4" />
            <SkeletonLoader CssClass="h-20 rounded-xl" />
        }
        else
        {
            <PotDisplay PotAmount="@ViewModel.PotAmount" OpponentDisplayName="@ViewModel.OpponentDisplayName" />
            @if (!string.IsNullOrEmpty(ViewModel.MatchRoundScoreText))
            {
                <p class="text-center text-xs text-muted-foreground">@ViewModel.MatchRoundScoreText</p>
            }
            <details class="rounded-xl border border-border bg-card/60 px-4 py-3 text-sm text-foreground">
                <summary class="cursor-pointer select-none font-semibold">@I18n.T("makopa_how_to_play_title")</summary>
                <div class="mt-2 whitespace-pre-line text-xs leading-relaxed text-muted-foreground">@I18n.T("makopa_rules_body")</div>
            </details>
            @if (!string.IsNullOrEmpty(ViewModel.TrickOutcomeMessage))
            {
                <p class="rounded-xl border border-primary/30 bg-primary/10 px-4 py-2 text-center text-sm text-foreground">@ViewModel.TrickOutcomeMessage</p>
            }
            <OpponentHand CardCount="@ViewModel.OpponentCards.Count" />
            <GameBoard LastPlayedCard="@ViewModel.LastPlayedCard" OnCardDropped="HandleCardDropped" />
            <PlayerHand Cards="@ViewModel.PlayerCards" IsPlayerTurn="@ViewModel.IsPlayerTurn" OnPlayCard="PlayCard" OnDragStart="HandleDragStart" OnDragEnd="HandleDragEnd" />
            <button type="button"
                    class="w-full rounded-xl border border-border bg-card px-4 py-3 text-sm font-semibold text-foreground disabled:cursor-not-allowed disabled:opacity-55"
                    disabled="@(!ViewModel.CanTakeCard || ViewModel.IsLoading || ViewModel.ShowInactivityOverlay)"
                    @onclick="TakeCard">
                @I18n.T("take_card")
            </button>
            <p class="text-center text-xs text-muted-foreground">
                @(ViewModel.CanTakeCard ? I18n.T("take_card_hint_enabled") : I18n.T("take_card_hint_disabled"))
            </p>
            <TurnIndicator IsPlayerTurn="@ViewModel.IsPlayerTurn" WaitingForOpponent="@ViewModel.WaitingForOpponent" />
        }
    </div>
</div>

@if (ViewModel.ShowInactivityOverlay)
{
    <div class="fixed inset-0 z-[100] flex items-center justify-center bg-black/60 px-4">
        <div class="w-full max-w-md rounded-2xl border border-border bg-card p-6 shadow-xl">
            <p class="text-center text-sm leading-relaxed text-foreground">
                @(ViewModel.InactivityShowButtons ? I18n.T("inactivity_warning_first") : I18n.T("inactivity_warning_second"))
            </p>
            <p class="mt-6 text-center font-mono text-4xl font-bold tabular-nums text-primary">
                @ViewModel.InactivityCountdownSeconds
            </p>
            @if (ViewModel.InactivityShowButtons)
            {
                <div class="mt-6 grid grid-cols-2 gap-3">
                    <button type="button"
                            class="rounded-xl border border-border bg-background px-4 py-3 text-sm font-semibold text-foreground disabled:opacity-50"
                            disabled="@ViewModel.InactivityActionBusy"
                            @onclick="OnInactivityContinue">
                        @I18n.T("continue_play")
                    </button>
                    <button type="button"
                            class="rounded-xl bg-destructive px-4 py-3 text-sm font-semibold text-destructive-foreground disabled:opacity-50"
                            disabled="@ViewModel.InactivityActionBusy"
                            @onclick="OnInactivityCancelGame">
                        @I18n.T("cancel_game")
                    </button>
                </div>
            }
        </div>
    </div>
}

@if (ViewModel.ShowGameResult)
{
    <WinCelebration Show="true" />
    <GameResultModal WinnerPlayerName="@ViewModel.WinnerPlayerName" />
}

@code {
    [Parameter] public string SessionId { get; set; } = "";

    private GamePlayViewModel ViewModel { get; set; } = null!;

    protected override void OnInitialized()
    {
        ViewModel = new GamePlayViewModel(GamePlayService, GameService, AppState, Nav, GameHubClient, GamePlayTestService, I18n);
        ViewModel.StateChanged += OnStateChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(SessionId))
            await ViewModel.LoadGameAsync(SessionId);
    }

    public async ValueTask DisposeAsync()
    {
        ViewModel.StateChanged -= OnStateChanged;
        await ViewModel.DisposeAsync();
    }

    private void OnStateChanged() => _ = InvokeAsync(StateHasChanged);

    private async Task PlayCard(CardViewModel card) => await ViewModel.PlayCardAsync(card);
    private async Task TakeCard() => await ViewModel.TakeCardAsync();

    private string? _draggedCardDisplayValue;

    private void HandleDragStart(string displayValue) => _draggedCardDisplayValue = displayValue;
    private void HandleDragEnd() => _draggedCardDisplayValue = null;

    private async Task HandleCardDropped()
    {
        if (ViewModel.ShowInactivityOverlay || ViewModel.IsLoading) return;
        if (string.IsNullOrEmpty(_draggedCardDisplayValue)) return;
        var card = ViewModel.PlayerCards.FirstOrDefault(c => c.DisplayValue == _draggedCardDisplayValue);
        if (card != null && card.IsPlayable)
            await ViewModel.PlayCardAsync(card);
        _draggedCardDisplayValue = null;
    }

    private async Task OnInactivityContinue() => await ViewModel.ContinueInactivityAsync();

    private async Task OnInactivityCancelGame() => await ViewModel.CancelGameFromInactivityAsync();
}
