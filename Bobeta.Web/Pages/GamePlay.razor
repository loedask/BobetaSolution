@page "/game/{SessionId}"
@layout MainLayout
@using Bobeta.Client.Models.Api
@using Bobeta.Web.Components.Game
@using Bobeta.Web.Shared.Services.Realtime
@inject GamePlayService GamePlayService
@inject IGameService GameService
@inject AppStateService AppState
@inject NavigationManager Nav
@inject GameHubClient GameHubClient
@inject GamePlayTestService GamePlayTestService
@inject I18nService I18n
@implements IAsyncDisposable

<div class="min-h-screen bg-background pb-24">
    <AppHeader Title="Game" ShowBack="true" BackHref="/dashboard" />

    <div class="space-y-4 px-5 py-4">
        <ErrorBanner Message="@ViewModel.ErrorMessage" />

        @if (ViewModel.ShowLoadingShell)
        {
            <SkeletonLoader CssClass="h-12 rounded-xl mb-4" />
            <SkeletonLoader CssClass="h-24 rounded-2xl mb-4" />
            <SkeletonLoader CssClass="h-32 rounded-2xl mb-4" />
            <SkeletonLoader CssClass="h-20 rounded-xl" />
        }
        else
        {
            <PotDisplay PotAmount="@ViewModel.PotAmount" OpponentDisplayName="@ViewModel.OpponentDisplayName" />
            @if (!string.IsNullOrEmpty(ViewModel.MatchRoundScoreText))
            {
                <p class="text-center text-xs text-muted-foreground">@ViewModel.MatchRoundScoreText</p>
            }
            @if (ViewModel.Variant == GameVariant.Kopo)
            {
                <details class="rounded-xl border border-border bg-card/60 px-4 py-3 text-sm text-foreground">
                    <summary class="cursor-pointer select-none font-semibold">@I18n.T("kopo_how_to_play_title")</summary>
                    <div class="mt-2 whitespace-pre-line text-xs leading-relaxed text-muted-foreground">@I18n.T("kopo_rules_body")</div>
                </details>
                @if (ViewModel.Kopo?.MustContinueChain == true)
                {
                    <p class="text-center text-xs text-primary">@I18n.T("kopo_continue_capture")</p>
                }
                @if (ViewModel.Kopo != null && ViewModel.MyPlayerId is { } myId)
                {
                    <KopoBoard BoardSize="@ViewModel.Kopo.BoardSize"
                                Pieces="@ViewModel.Kopo.Pieces"
                                MyPlayerId="@myId"
                                SelectionPath="@ViewModel.KopoSelectionPath"
                                MustContinueChain="@ViewModel.Kopo.MustContinueChain"
                                CanInteract="@(ViewModel.IsPlayerTurn && !ViewModel.IsSendingMove && !ViewModel.ShowInactivityOverlay)"
                                OnCellClicked="OnKopoCellClicked" />
                }
                @if (ViewModel.IsSendingMove)
                {
                    <p class="text-center text-sm text-muted-foreground">@I18n.T("sending_move")</p>
                }
            }
            else if (ViewModel.Variant == GameVariant.Ngola)
            {
                <details class="rounded-xl border border-border bg-card/60 px-4 py-3 text-sm text-foreground">
                    <summary class="cursor-pointer select-none font-semibold">@I18n.T("ngola_how_to_play_title")</summary>
                    <div class="mt-2 whitespace-pre-line text-xs leading-relaxed text-muted-foreground">@I18n.T("ngola_rules_body")</div>
                </details>
                @if (ViewModel.Ngola != null)
                {
                    <NgolaBoard MyPits="@ViewModel.Ngola.MyPits"
                                OpponentPits="@ViewModel.Ngola.OpponentPits"
                                MyScore="@ViewModel.Ngola.MyScore"
                                OpponentScore="@ViewModel.Ngola.OpponentScore"
                                CanInteract="@(ViewModel.IsPlayerTurn && !ViewModel.IsSendingMove && !ViewModel.ShowInactivityOverlay)"
                                OnPitClicked="OnNgolaPitClicked" />
                }
                @if (ViewModel.IsSendingMove)
                {
                    <p class="text-center text-sm text-muted-foreground">@I18n.T("sending_move")</p>
                }
            }
            else if (ViewModel.Variant == GameVariant.Domino)
            {
                <details class="rounded-xl border border-border bg-card/60 px-4 py-3 text-sm text-foreground">
                    <summary class="cursor-pointer select-none font-semibold">@I18n.T("domino_how_to_play_title")</summary>
                    <div class="mt-2 whitespace-pre-line text-xs leading-relaxed text-muted-foreground">@I18n.T("domino_rules_body")</div>
                </details>
                @if (ViewModel.Domino != null)
                {
                    <DominoBoard MyHand="@ViewModel.Domino.MyHand"
                                 OpponentHandCount="@ViewModel.Domino.OpponentHandCount"
                                 BoneyardCount="@ViewModel.Domino.BoneyardCount"
                                 Chain="@ViewModel.Domino.Chain"
                                 LeftEnd="@ViewModel.Domino.LeftEnd"
                                 RightEnd="@ViewModel.Domino.RightEnd"
                                 IsOpening="@ViewModel.Domino.IsOpening"
                                 OpeningTile="@ViewModel.Domino.OpeningTile"
                                 MustDraw="@ViewModel.Domino.MustDraw"
                                 MustPass="@ViewModel.Domino.MustPass"
                                 CanInteract="@(ViewModel.IsPlayerTurn && !ViewModel.IsSendingMove && !ViewModel.ShowInactivityOverlay)"
                                 OnAction="OnDominoAction" />
                }
                @if (ViewModel.IsSendingMove)
                {
                    <p class="text-center text-sm text-muted-foreground">@I18n.T("sending_move")</p>
                }
            }
            else if (ViewModel.Variant == GameVariant.Abbia)
            {
                <details class="rounded-xl border border-border bg-card/60 px-4 py-3 text-sm text-foreground">
                    <summary class="cursor-pointer select-none font-semibold">@I18n.T("abbia_how_to_play_title")</summary>
                    <div class="mt-2 whitespace-pre-line text-xs leading-relaxed text-muted-foreground">@I18n.T("abbia_rules_body")</div>
                </details>
                @if (ViewModel.Abbia != null)
                {
                    <AbbiaBoard Abbia="@ViewModel.Abbia"
                                CanInteract="@(ViewModel.IsPlayerTurn && !ViewModel.IsSendingMove && !ViewModel.ShowInactivityOverlay)"
                                OnThrow="OnAbbiaThrow" />
                }
                @if (ViewModel.IsSendingMove)
                {
                    <p class="text-center text-sm text-muted-foreground">@I18n.T("sending_move")</p>
                }
            }
            else if (ViewModel.Variant == GameVariant.Nzengue)
            {
                <details class="rounded-xl border border-border bg-card/60 px-4 py-3 text-sm text-foreground">
                    <summary class="cursor-pointer select-none font-semibold">@I18n.T("nzengue_how_to_play_title")</summary>
                    <div class="mt-2 whitespace-pre-line text-xs leading-relaxed text-muted-foreground">@I18n.T("nzengue_rules_body")</div>
                </details>
                @if (ViewModel.Nzengue != null)
                {
                    <NzengueBoard Nzengue="@ViewModel.Nzengue"
                                  CanInteract="@(ViewModel.IsPlayerTurn && !ViewModel.IsSendingMove && !ViewModel.ShowInactivityOverlay)"
                                  OnPlay="OnNzenguePlay" />
                }
                @if (ViewModel.IsSendingMove)
                {
                    <p class="text-center text-sm text-muted-foreground">@I18n.T("sending_move")</p>
                }
            }
            else
            {
                <details class="rounded-xl border border-border bg-card/60 px-4 py-3 text-sm text-foreground">
                    <summary class="cursor-pointer select-none font-semibold">@I18n.T("makopa_how_to_play_title")</summary>
                    <div class="mt-2 whitespace-pre-line text-xs leading-relaxed text-muted-foreground">@I18n.T("makopa_rules_body")</div>
                </details>
                @if (!string.IsNullOrEmpty(ViewModel.TrickOutcomeMessage))
                {
                    <p class="rounded-xl border border-primary/30 bg-primary/10 px-4 py-2 text-center text-sm text-foreground">@ViewModel.TrickOutcomeMessage</p>
                }
                <div class="relative">
                    <OpponentHand CardCount="@ViewModel.OpponentCards.Count" />
                    <GameBoard LastPlayedCard="@ViewModel.LastPlayedCard" OnCardDropped="HandleCardDropped" />
                    <PlayerHand
                        Cards="@ViewModel.PlayerCards"
                        IsPlayerTurn="@ViewModel.IsPlayerTurn"
                        CanInteract="@(ViewModel.IsPlayerTurn && !ViewModel.IsSendingMove && !ViewModel.ShowInactivityOverlay)"
                        OnPlayCard="PlayCard"
                        OnDragStart="HandleDragStart"
                        OnDragEnd="HandleDragEnd" />
                    @if (ViewModel.IsSendingMove)
                    {
                        <div class="pointer-events-auto absolute inset-0 z-20 flex items-center justify-center rounded-2xl bg-background/75 backdrop-blur-sm">
                            <p class="rounded-xl border border-primary/40 bg-card px-5 py-3 text-sm font-semibold text-foreground shadow-lg">
                                @I18n.T("sending_move")
                            </p>
                        </div>
                    }
                </div>
                <button type="button"
                        class="w-full rounded-xl border border-border bg-card px-4 py-3 text-sm font-semibold text-foreground disabled:cursor-not-allowed disabled:opacity-55"
                        disabled="@(!ViewModel.CanTakeCard || ViewModel.IsSendingMove || ViewModel.ShowInactivityOverlay)"
                        @onclick="TakeCard">
                    @I18n.T("take_card")
                </button>
                <p class="text-center text-xs text-muted-foreground">
                    @(ViewModel.CanTakeCard ? I18n.T("take_card_hint_enabled") : I18n.T("take_card_hint_disabled"))
                </p>
            }
            <TurnIndicator IsPlayerTurn="@ViewModel.IsPlayerTurn" WaitingForOpponent="@ViewModel.WaitingForOpponent" />
        }
    </div>
</div>

@if (ViewModel.ShowInactivityOverlay)
{
    <div class="fixed inset-0 z-[100] flex items-center justify-center bg-black/60 px-4">
        <div class="w-full max-w-md rounded-2xl border border-border bg-card p-6 shadow-xl">
            <p class="text-center text-sm leading-relaxed text-foreground">
                @(ViewModel.InactivityShowButtons ? I18n.T("inactivity_warning_first") : I18n.T("inactivity_warning_second"))
            </p>
            <p class="mt-6 text-center font-mono text-4xl font-bold tabular-nums text-primary">
                @ViewModel.InactivityCountdownSeconds
            </p>
            @if (ViewModel.InactivityShowButtons)
            {
                <div class="mt-6 grid grid-cols-2 gap-3">
                    <button type="button"
                            class="rounded-xl border border-border bg-background px-4 py-3 text-sm font-semibold text-foreground disabled:opacity-50"
                            disabled="@ViewModel.InactivityActionBusy"
                            @onclick="OnInactivityContinue">
                        @I18n.T("continue_play")
                    </button>
                    <button type="button"
                            class="rounded-xl bg-destructive px-4 py-3 text-sm font-semibold text-destructive-foreground disabled:opacity-50"
                            disabled="@ViewModel.InactivityActionBusy"
                            @onclick="OnInactivityCancelGame">
                        @I18n.T("cancel_game")
                    </button>
                </div>
            }
        </div>
    </div>
}

@if (ViewModel.ShowForfeitConfirm)
{
    <div class="fixed inset-0 z-[60] flex items-center justify-center bg-background/80 backdrop-blur-sm px-6">
        <div class="w-full max-w-sm rounded-2xl border border-border bg-card p-6 text-center">
            <h3 class="font-display text-xl font-bold text-foreground mb-2">@I18n.T("forfeit_confirm_title")</h3>
            <p class="text-sm text-muted-foreground mb-6">@I18n.T("forfeit_confirm")</p>
            <div class="flex flex-col gap-2">
                <button type="button"
                        class="gold-gradient inline-flex items-center justify-center w-full rounded-xl py-3 font-semibold text-primary-foreground disabled:opacity-50"
                        disabled="@ViewModel.ForfeitActionBusy"
                        @onclick="OnConfirmForfeit">
                    @I18n.T("yes")
                </button>
                <button type="button"
                        class="rounded-xl border border-border bg-background px-4 py-3 text-sm font-semibold text-foreground disabled:opacity-50"
                        disabled="@ViewModel.ForfeitActionBusy"
                        @onclick="OnDismissForfeit">
                    @I18n.T("no")
                </button>
            </div>
        </div>
    </div>
}

@if (ViewModel.ShowGameResult)
{
    @if (!ViewModel.IsDraw)
    {
        <WinCelebration Show="true" />
    }
    <GameResultModal WinnerPlayerName="@ViewModel.WinnerPlayerName" IsDraw="@ViewModel.IsDraw" EndedByForfeit="@ViewModel.EndedByForfeit" />
}

@code {
    [Parameter] public string SessionId { get; set; } = "";

    private GamePlayViewModel ViewModel { get; set; } = null!;
    private IDisposable? _locationChangingRegistration;

    protected override void OnInitialized()
    {
        ViewModel = new GamePlayViewModel(GamePlayService, GameService, AppState, Nav, GameHubClient, GamePlayTestService, I18n);
        ViewModel.StateChanged += OnStateChanged;
        _locationChangingRegistration = Nav.RegisterLocationChangingHandler(OnLocationChanging);
    }

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(SessionId))
            await ViewModel.LoadGameAsync(SessionId);
    }

    private ValueTask OnLocationChanging(LocationChangingContext context)
    {
        if (!ViewModel.ShouldConfirmLeave)
            return ValueTask.CompletedTask;

        var target = context.TargetLocation;
        var current = Nav.ToBaseRelativePath(Nav.Uri);
        var targetRel = Nav.ToBaseRelativePath(target);
        if (string.Equals(current, targetRel, StringComparison.OrdinalIgnoreCase))
            return ValueTask.CompletedTask;

        context.PreventNavigation();
        ViewModel.RequestForfeitConfirm();
        return ValueTask.CompletedTask;
    }

    public async ValueTask DisposeAsync()
    {
        _locationChangingRegistration?.Dispose();
        ViewModel.StateChanged -= OnStateChanged;
        await ViewModel.DisposeAsync();
    }

    private void OnStateChanged() => _ = InvokeAsync(StateHasChanged);

    private async Task PlayCard(CardViewModel card) => await ViewModel.PlayCardAsync(card);
    private async Task TakeCard() => await ViewModel.TakeCardAsync();

    private string? _draggedCardDisplayValue;

    private void HandleDragStart(string displayValue) => _draggedCardDisplayValue = displayValue;
    private void HandleDragEnd() => _draggedCardDisplayValue = null;

    private async Task HandleCardDropped()
    {
        if (ViewModel.ShowInactivityOverlay || ViewModel.IsSendingMove) return;
        if (string.IsNullOrEmpty(_draggedCardDisplayValue)) return;
        var card = ViewModel.PlayerCards.FirstOrDefault(c => c.DisplayValue == _draggedCardDisplayValue);
        if (card != null && card.IsPlayable)
            await ViewModel.PlayCardAsync(card);
        _draggedCardDisplayValue = null;
    }

    private async Task OnInactivityContinue() => await ViewModel.ContinueInactivityAsync();

    private async Task OnInactivityCancelGame() => await ViewModel.CancelGameFromInactivityAsync();

    private async Task OnConfirmForfeit() => await ViewModel.ConfirmForfeitAndLeaveAsync();
    private void OnDismissForfeit() => ViewModel.DismissForfeitConfirm();

    private async Task OnKopoCellClicked((int Row, int Col) cell) => await ViewModel.OnKopoSquareClickedAsync(cell.Row, cell.Col);
    private async Task OnNgolaPitClicked(int pitIndex) => await ViewModel.OnNgolaPitClickedAsync(pitIndex);
    private async Task OnDominoAction((string Action, int? High, int? Low, string? End) move) =>
        await ViewModel.OnDominoActionAsync(move.Action, move.High, move.Low, move.End);
    private async Task OnAbbiaThrow() => await ViewModel.OnAbbiaThrowAsync();
    private async Task OnNzenguePlay((int? From, int To) move) =>
        await ViewModel.OnNzenguePlayAsync(move.From, move.To);
}
