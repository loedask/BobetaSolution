@page "/dashboard"
@inject NavigationManager Nav
@inject WalletService WalletService
@inject AppStateService AppState
@inject I18nService I18n

<div class="min-h-screen bg-background pb-24">
    <div class="flex items-center justify-between px-5 pt-6 pb-4">
        <div>
            <p class="text-sm text-muted-foreground">@I18n.T("welcome_back")</p>
            <h1 class="font-display text-xl font-bold text-foreground">@(AppState.State.CurrentPlayerName ?? "Player")</h1>
        </div>
        <button type="button" class="relative flex h-10 w-10 items-center justify-center rounded-xl bg-card">
            <svg class="h-5 w-5 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" /></svg>
            <div class="absolute -right-0.5 -top-0.5 h-2.5 w-2.5 rounded-full bg-accent"></div>
        </button>
    </div>

    <div class="space-y-6 px-5">
        <WalletCard Balance="@((decimal)AppState.State.WalletBalance)" OnDeposit="GoDeposit" OnWithdraw="GoWithdraw" />

        <div class="grid grid-cols-3 gap-3">
            <a href="/dashboard" class="gold-gradient flex flex-col items-center gap-2 rounded-xl p-4 transition-all active:scale-[0.97]">
                <svg class="h-6 w-6 text-primary-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                <span class="text-xs font-semibold text-primary-foreground">@I18n.T("create_game")</span>
            </a>
            <a href="/join" class="green-gradient flex flex-col items-center gap-2 rounded-xl p-4 transition-all active:scale-[0.97]">
                <svg class="h-6 w-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                <span class="text-xs font-semibold text-white">@I18n.T("join_game")</span>
            </a>
            <a href="/history" class="flex flex-col items-center gap-2 rounded-xl bg-secondary p-4 transition-all active:scale-[0.97]">
                <svg class="h-6 w-6 text-secondary-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                <span class="text-xs font-semibold text-secondary-foreground">@I18n.T("history")</span>
            </a>
        </div>

        <div>
            <div class="mb-3 flex items-center justify-between">
                <h2 class="font-display text-lg font-bold text-foreground">@I18n.T("recent_activity")</h2>
                <a href="/history" class="text-sm text-primary hover:underline">@I18n.T("see_all")</a>
            </div>
            <div class="space-y-2">
                @if (_transactions.Count == 0)
                {
                    <p class="text-sm text-muted-foreground py-4">No recent activity</p>
                }
                @foreach (var tx in _transactions)
                {
                    <TransactionItem Description="@tx.Description" Time="@tx.Time" Amount="@tx.Amount" />
                }
            </div>
        </div>

        <div class="flex items-center gap-2 rounded-xl bg-accent/5 p-3 text-xs text-accent">
            <svg class="h-4 w-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            <span>@I18n.T("trust_message")</span>
        </div>
    </div>
</div>

@code {
    private List<(string Description, string Time, decimal Amount)> _transactions = new();

    protected override async Task OnInitializedAsync()
    {
        var balanceRes = await WalletService.GetBalanceAsync();
        if (balanceRes.IsSuccess && balanceRes.Data != null)
        {
            AppState.State.WalletBalance = balanceRes.Data.Balance;
            AppState.State.LockedBalance = balanceRes.Data.LockedBalance;
            await AppState.SaveAsync();
        }
        var txRes = await WalletService.GetTransactionsAsync(0, 10);
        if (txRes.IsSuccess && txRes.Data != null)
            _transactions = txRes.Data.Select(t => (
                t.Type == "Deposit" ? I18n.T("deposit_label") : t.Type == "Withdraw" ? "Withdraw" : t.Type,
                t.CreatedAt.ToString("g"),
                t.Amount)).ToList();
    }

    private void GoDeposit() => Nav.NavigateTo("/deposit");
    private void GoWithdraw() => Nav.NavigateTo("/withdraw");
}
