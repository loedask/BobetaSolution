@page "/login"
@layout AuthLayout
@implements IDisposable
@inject PhoneLoginViewModel ViewModel
@inject I18nService I18n

<div class="relative flex min-h-screen flex-col">
    <div class="relative z-10 flex flex-1 flex-col items-center justify-center px-6 w-full max-w-sm">
        @if (string.Equals(EndSessionReason, "session-expired", StringComparison.OrdinalIgnoreCase))
        {
            <div class="mb-4 w-full rounded-xl border border-primary/35 bg-gradient-to-br from-primary/12 via-primary/5 to-transparent px-4 py-3 text-sm text-foreground shadow-sm">
                <div class="flex gap-3">
                    <div class="mt-0.5 flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg bg-primary/20 text-primary" aria-hidden="true">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                    </div>
                    <p class="leading-snug text-muted-foreground">@I18n.T("session_expired_banner")</p>
                </div>
            </div>
        }
        <ErrorBanner Message="@ViewModel.ErrorMessage" />
        <div class="mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-primary/10">
            <svg class="h-8 w-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
        </div>
        <h2 class="mb-2 font-display text-2xl font-bold text-foreground">@I18n.T("enter_number")</h2>
        <p class="mb-8 text-center text-sm text-muted-foreground">@I18n.T("send_code_desc")</p>
        <div class="mb-6 w-full">
            <div class="flex items-center gap-2 rounded-xl border border-border bg-card px-4 py-3 focus-within:border-primary/50 transition-all">
                <CountryCodeSelector Dial="@ViewModel.CountryDial" DialChanged="OnCountryChanged" />
                <input type="tel" @bind="ViewModel.Phone" @bind:event="oninput" placeholder="@I18n.T("phone_placeholder")" maxlength="@ViewModel.PhoneDigits"
                       class="flex-1 bg-transparent text-lg text-foreground outline-none placeholder:text-muted-foreground/50" />
            </div>
        </div>
        <PrimaryButton OnClick="SendCode" Disabled="@(!ViewModel.CanSubmit)" CssClass="w-full">
            @if (ViewModel.IsLoading) { <LoadingSpinner /> } else { @I18n.T("send_code") }
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </PrimaryButton>
    </div>
</div>

@code {
    // Set from query when HandleUnauthorizedAsync sends the user here after API 401.
    [SupplyParameterFromQuery(Name = "reason")]
    public string? EndSessionReason { get; set; }

    protected override void OnInitialized()
    {
        ViewModel.StateChanged += OnStateChanged;
    }

    public void Dispose() => ViewModel.StateChanged -= OnStateChanged;

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    private void OnCountryChanged((string Dial, int Digits) value)
    {
        ViewModel.SetCountry(value.Dial, value.Digits);
    }

    private async Task SendCode() => await ViewModel.SendOtpAsync();
}
