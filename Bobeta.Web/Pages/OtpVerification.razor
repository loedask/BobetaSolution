@page "/verify"
@layout AuthLayout
@implements IDisposable
@using Bobeta.Domain.Authentication
@inject OtpVerificationViewModel ViewModel
@inject I18nService I18n

<div class="relative flex min-h-screen flex-col">
    <div class="relative z-10 flex flex-1 flex-col items-center justify-center px-6 w-full max-w-sm">
        <ErrorBanner Message="@ViewModel.ErrorMessage" />
        <h2 class="mb-2 font-display text-2xl font-bold text-foreground">@I18n.T("verification_code")</h2>
        <p class="mb-8 text-center text-sm text-muted-foreground">@I18n.T("enter_otp_desc") @ViewModel.PhoneNumber</p>
        <div class="mb-6 flex justify-center gap-3">
            @for (var i = 0; i < PhoneAuthConstants.OtpDigitLength; i++)
            {
                var idx = i;
                <input @key="idx"
                       @ref="_otpInputs[idx]"
                       type="text"
                       maxlength="1"
                       inputmode="numeric"
                       autocomplete="@(idx == 0 ? "one-time-code" : "off")"
                       class="h-14 w-14 rounded-xl border border-border bg-card text-center font-display text-2xl font-bold text-foreground outline-none focus:border-primary transition-all"
                       value="@(ViewModel.Otp.Length > idx ? ViewModel.Otp[idx].ToString() : "")"
                       @oninput="e => OnOtpInputAsync(idx, e)" />
            }
        </div>
        <PrimaryButton OnClick="Verify" Disabled="@(!ViewModel.CanVerify)" CssClass="w-full">
            @if (ViewModel.IsLoading) { <LoadingSpinner /> } else { @I18n.T("verify") }
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </PrimaryButton>
        <button type="button" class="mt-4 text-sm text-primary hover:underline" @onclick="Resend" disabled="@ViewModel.IsLoading">@I18n.T("resend_code")</button>
    </div>
</div>

@code {
    private readonly ElementReference[] _otpInputs = new ElementReference[PhoneAuthConstants.OtpDigitLength];

    protected override void OnInitialized() => ViewModel.StateChanged += OnStateChanged;
    public void Dispose() => ViewModel.StateChanged -= OnStateChanged;
    private void OnStateChanged() => InvokeAsync(StateHasChanged);
    private async Task Verify() => await ViewModel.VerifyAsync();
    private async Task Resend() => await ViewModel.ResendAsync();

    private async Task OnOtpInputAsync(int index, ChangeEventArgs e)
    {
        var raw = e.Value?.ToString() ?? "";
        ViewModel.UpdateOtp(index, raw);
        await Task.Yield();

        var hasDigit = raw.Trim().Length > 0;
        if (hasDigit && index < PhoneAuthConstants.OtpDigitLength - 1)
            await _otpInputs[index + 1].FocusAsync();
        else if (!hasDigit && index > 0)
            await _otpInputs[index - 1].FocusAsync();
    }
}
