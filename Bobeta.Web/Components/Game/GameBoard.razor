<div class="game-board-dropzone rounded-2xl border border-border bg-card p-6 min-h-[120px] flex items-center justify-center transition-colors @(_dragOver ? "border-primary bg-primary/5" : "")"
     @ondragover="HandleDragOver"
     @ondragover:preventDefault
     @ondragleave="HandleDragLeave"
     @ondrop="HandleDrop"
     @ondrop:preventDefault>
    @if (LastPlayedCard != null)
    {
        <div class="playing-card playing-card--board rounded-xl border-2 border-primary/60 bg-card-surface/80 p-1 shadow-lg card-play-animation">
            <PlayingCardFace Card="@LastPlayedCard" CssClass="playing-card-face--lg" />
        </div>
    }
    else
    {
        <span class="text-muted-foreground text-sm">@(_dragOver ? "Drop card here" : "No card played yet")</span>
    }
</div>

@code {
    [Parameter] public CardViewModel? LastPlayedCard { get; set; }
    [Parameter] public EventCallback OnCardDropped { get; set; }

    private bool _dragOver;

    private void HandleDragOver(DragEventArgs e)
    {
        _dragOver = true;
    }

    private void HandleDragLeave(DragEventArgs e)
    {
        _dragOver = false;
    }

    private void HandleDrop(DragEventArgs e)
    {
        _dragOver = false;
        OnCardDropped.InvokeAsync();
    }
}
