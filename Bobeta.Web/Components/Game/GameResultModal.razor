<div class="fixed inset-0 z-50 flex items-center justify-center bg-background/80 backdrop-blur-sm px-6">
    <div class="w-full max-w-sm rounded-2xl border border-border bg-card p-6 text-center">
        <h3 class="font-display text-xl font-bold text-foreground mb-2">@(WinnerPlayerName == "You" ? "You won!" : "Game over")</h3>
        <p class="text-sm text-muted-foreground mb-6">@WinnerPlayerName won this round.</p>
        <a href="/dashboard" class="gold-gradient inline-flex items-center justify-center w-full rounded-xl py-3 font-semibold text-primary-foreground">Back to Dashboard</a>
    </div>
</div>

@code {
    [Parameter] public string? WinnerPlayerName { get; set; }
}
