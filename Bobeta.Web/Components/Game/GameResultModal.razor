@inject I18nService I18n

<div class="fixed inset-0 z-50 flex items-center justify-center bg-background/80 backdrop-blur-sm px-6">
    <div class="w-full max-w-sm rounded-2xl border border-border bg-card p-6 text-center">
        <h3 class="font-display text-xl font-bold text-foreground mb-2">@Title</h3>
        <p class="text-sm text-muted-foreground mb-6">@Body</p>
        <a href="/dashboard" class="gold-gradient inline-flex items-center justify-center w-full rounded-xl py-3 font-semibold text-primary-foreground">@I18n.T("back_to_dashboard")</a>
    </div>
</div>

@code {
    [Parameter] public string? WinnerPlayerName { get; set; }
    [Parameter] public bool IsDraw { get; set; }
    [Parameter] public bool EndedByForfeit { get; set; }

    private string Title
    {
        get
        {
            if (IsDraw)
                return I18n.T("result_draw_title");
            if (EndedByForfeit && WinnerPlayerName == "You")
                return I18n.T("forfeit_win");
            if (EndedByForfeit)
                return I18n.T("forfeit_loss");
            return WinnerPlayerName == "You" ? I18n.T("result_you_won") : I18n.T("result_game_over");
        }
    }

    private string Body
    {
        get
        {
            if (IsDraw)
                return I18n.T("result_draw_body");
            if (EndedByForfeit && WinnerPlayerName == "You")
                return I18n.T("forfeit_win_body");
            if (EndedByForfeit)
                return I18n.T("forfeit_loss_body");
            return string.Format(I18n.T("result_won_round"), WinnerPlayerName ?? "Opponent");
        }
    }
}
