<div class="flex flex-wrap justify-center gap-2 p-4">
    @for (var i = 0; i < CardCount; i++)
    {
        <div class="playing-card-back h-[4.5rem] w-[3.15rem] rounded-lg border border-border flex items-center justify-center shrink-0" aria-hidden="true">
            <span class="text-[0.65rem] font-semibold tracking-widest text-muted-foreground/70">?</span>
        </div>
    }
</div>

@code {
    [Parameter] public int CardCount { get; set; }
}
