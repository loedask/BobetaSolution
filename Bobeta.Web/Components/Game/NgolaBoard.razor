<div class="mx-auto max-w-lg rounded-[2rem] border border-amber-700/40 bg-gradient-to-br from-amber-700 via-amber-800 to-amber-950 p-4 shadow-xl">
    <div class="mb-3 flex items-center justify-between px-2 text-xs font-semibold text-amber-50">
        <span>Opponent: @OpponentScore</span>
        <span>You: @MyScore</span>
    </div>
    <div class="grid grid-cols-8 gap-1.5 rounded-2xl bg-black/15 p-2">
        @for (var index = 0; index < OpponentPits.Count; index++)
        {
            <div class="@PitClass(interactive: false)">
                <span class="text-sm font-bold text-amber-950">@OpponentPits[index]</span>
            </div>
        }
        @for (var index = 0; index < MyPits.Count; index++)
        {
            var pit = index;
            var canSow = CanInteract && MyPits[pit] >= 2;
            <button type="button"
                    class="@PitClass(canSow)"
                    disabled="@(!canSow)"
                    aria-label="Pit @(pit + 1), @MyPits[pit] seeds"
                    @onclick="() => OnPitClicked.InvokeAsync(pit)">
                <span class="text-sm font-bold text-amber-950">@MyPits[pit]</span>
            </button>
        }
    </div>
</div>

@code {
    [Parameter] public IReadOnlyList<int> MyPits { get; set; } = Array.Empty<int>();
    [Parameter] public IReadOnlyList<int> OpponentPits { get; set; } = Array.Empty<int>();
    [Parameter] public int MyScore { get; set; }
    [Parameter] public int OpponentScore { get; set; }
    [Parameter] public bool CanInteract { get; set; }
    [Parameter] public EventCallback<int> OnPitClicked { get; set; }

    private static string PitClass(bool interactive) =>
        "flex aspect-square min-w-0 items-center justify-center rounded-full border-2 border-amber-950/30 bg-amber-200 shadow-inner "
        + (interactive
            ? "cursor-pointer ring-2 ring-primary/70 transition-transform active:scale-95"
            : "cursor-default opacity-80");
}
