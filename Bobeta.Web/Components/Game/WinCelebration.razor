@inject IJSRuntime JS
@if (Show)
{
    <div class="win-celebration fixed inset-0 pointer-events-none z-40 flex items-center justify-center overflow-hidden">
        <div class="win-glow absolute w-64 h-64 rounded-full" style="animation: win-pulse 1.5s ease-in-out 3;"></div>
        @for (var i = 0; i < 40; i++)
        {
            var delay = (i % 8) * 0.06;
            var tx = ((i * 31) % 120) - 60;
            var color = (i % 3) switch { 0 => "hsl(45 90% 55%)", 1 => "hsl(35 85% 45%)", _ => "hsl(50 95% 65%)" };
            <div class="confetti-piece absolute w-2 h-2 rounded-sm"
                 style="left: 50%; top: 35%; background: @color; animation: confetti-fall 2.2s ease-out @(delay)s forwards; --tx: @(tx)px;"></div>
        }
    </div>
}

@code {
    [Parameter] public bool Show { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        if (Show)
        {
            try
            {
                await JS.InvokeVoidAsync("eval", "navigator.vibrate && navigator.vibrate(200)");
            }
            catch { /* ignore */ }
        }
    }
}
