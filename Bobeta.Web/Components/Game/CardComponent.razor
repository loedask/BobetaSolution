@* Renders a single card; uses existing Tailwind / gold / dark conventions. *@
@if (Card != null)
{
    <button type="button" class="rounded-lg border border-border bg-card p-2 text-foreground transition-all hover:border-primary/50 active:scale-95 disabled:opacity-50 disabled:pointer-events-none @Card.CssClass @CssClass" disabled="@Disabled" @onclick="() => OnClick.InvokeAsync(Card)">
        <span class="font-display text-sm font-bold">@Card.DisplayValue</span>
    </button>
}

@code {
    [Parameter] public CardViewModel? Card { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public EventCallback<CardViewModel> OnClick { get; set; }
}
