@* Playing-card chrome + drag/click; face layout matches <see cref="PlayingCardFace"/>. *@
@if (Card != null)
{
    <button type="button" draggable="@(!Disabled)"
            class="playing-card playing-card--btn card-draggable @CssClass @Card.CssClass disabled:opacity-50 disabled:pointer-events-none"
            disabled="@Disabled"
            @onclick="() => OnClick.InvokeAsync(Card)"
            @ondragstart="HandleDragStart"
            @ondragend="HandleDragEnd">
        <PlayingCardFace Card="@Card" />
    </button>
}

@code {
    [Parameter] public CardViewModel? Card { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public EventCallback<CardViewModel> OnClick { get; set; }
    [Parameter] public EventCallback<string> OnDragStart { get; set; }
    [Parameter] public EventCallback OnDragEnd { get; set; }

    private void HandleDragStart(DragEventArgs e)
    {
        if (Card == null || Disabled) return;
        e.DataTransfer.EffectAllowed = "move";
        _ = OnDragStart.InvokeAsync(Card.DisplayValue);
    }

    private void HandleDragEnd(DragEventArgs e)
    {
        _ = OnDragEnd.InvokeAsync();
    }
}
