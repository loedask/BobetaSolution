@inject I18nService I18n

@{
    var half = PotAmount > 0 ? PotAmount / 2m : 0m;
    var halfStr = half.ToString("N0");
}

<div class="relative overflow-hidden rounded-2xl border border-border bg-card">
    <div class="pointer-events-none absolute -right-8 -top-8 h-24 w-24 rounded-full bg-primary/10 blur-2xl"></div>
    <div class="pointer-events-none absolute -bottom-6 -left-6 h-20 w-20 rounded-full bg-accent/10 blur-xl"></div>

    <div class="relative px-4 pt-3 pb-2">
        <div class="mb-1 flex items-start justify-between gap-3">
            <div>
                <p class="text-[10px] font-semibold uppercase tracking-[0.2em] text-muted-foreground/90">@I18n.T("pot_table")</p>
                <p class="font-display text-2xl font-bold leading-tight gold-text tabular-nums">
                    @PotAmount.ToString("N0")<span class="ml-1 text-sm font-semibold text-muted-foreground">FCFA</span>
                </p>
            </div>
            <div class="flex shrink-0 flex-col items-end gap-0.5 pt-0.5" title="@string.Format(I18n.T("pot_chip_title"), halfStr)">
                <span class="text-[9px] font-medium uppercase tracking-wide text-muted-foreground">@I18n.T("pot_seats")</span>
                <div class="flex items-center gap-1">
                    <span class="inline-flex h-7 min-w-[2.25rem] items-center justify-center rounded-full border border-primary/40 bg-gradient-to-b from-primary/25 to-primary/10 px-2 font-mono text-xs font-bold text-primary shadow-sm tabular-nums">@halfStr</span>
                    <span class="select-none text-primary/70">+</span>
                    <span class="inline-flex h-7 min-w-[2.25rem] items-center justify-center rounded-full border border-primary/40 bg-gradient-to-b from-primary/25 to-primary/10 px-2 font-mono text-xs font-bold text-primary shadow-sm tabular-nums">@halfStr</span>
                </div>
            </div>
        </div>
    </div>

    <div class="relative border-t border-border/60 bg-gradient-to-r from-secondary/30 via-secondary/50 to-secondary/30 px-4 py-2">
        <p class="text-center text-[11px] leading-relaxed text-muted-foreground">
            @string.Format(I18n.T("pot_activity_hint"), halfStr)
        </p>
    </div>
</div>

@code {
    [Parameter] public decimal PotAmount { get; set; }
}
