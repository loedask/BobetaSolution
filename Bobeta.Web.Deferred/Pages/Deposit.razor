@page "/deposit"
@implements IDisposable
@using Microsoft.AspNetCore.Components.WebAssembly.Hosting
@inject DepositViewModel ViewModel
@inject I18nService I18n
@inject IWebAssemblyHostEnvironment HostEnvironment

<div class="min-h-screen bg-background pb-24">
    <AppHeader Title="@I18n.T("deposit")" ShowBack="true" BackHref="/dashboard" />

    <div class="space-y-5 px-5">
        <ErrorBanner Message="@ViewModel.ErrorMessage" />

        @if (HostEnvironment.IsDevelopment())
        {
            <div class="rounded-xl border border-amber-500/35 bg-amber-500/10 px-4 py-3 text-xs leading-relaxed text-amber-100/90">
                @I18n.T("dev_test_deposit_notice")
            </div>
        }

        <div class="card-surface glow-gold overflow-hidden rounded-2xl border border-border/50 px-5 py-5">
            <div class="flex items-start justify-between gap-3">
                <div>
                    <div class="mb-2 flex items-center gap-2">
                        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary/10">
                            <svg class="h-4 w-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" /></svg>
                        </span>
                        <span class="text-xs font-medium uppercase tracking-wider text-muted-foreground">@I18n.T("current_balance")</span>
                    </div>
                    <p class="gold-text font-display text-3xl font-bold tracking-tight">@ViewModel.CurrentBalance.ToString("N0") <span class="text-lg">FCFA</span></p>
                </div>
                <span class="rounded-full border border-accent/25 bg-accent/10 px-2.5 py-1 text-[11px] font-semibold text-accent">MoMo</span>
            </div>
        </div>

        @if (ViewModel.IsSuccess)
        {
            <div class="card-surface flex flex-col items-center gap-3 rounded-2xl border border-accent/30 px-6 py-12 text-center">
                <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-accent/15 ring-1 ring-accent/30">
                    <svg class="h-8 w-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                </div>
                <p class="font-display text-xl font-bold text-foreground">@I18n.T("deposit_successful")</p>
                <p class="text-sm text-muted-foreground">
                    <span class="font-semibold text-accent">+@ViewModel.SuccessAmount.ToString("N0") FCFA</span>
                    @I18n.T("added_to_wallet")
                </p>
            </div>
        }
        else
        {
            <div class="card-surface space-y-6 rounded-2xl border border-border/50 px-5 py-6">
                <div>
                    <label class="mb-2 block text-sm font-semibold text-foreground">@I18n.T("amount_fcfa")</label>
                    <div class="rounded-2xl border border-border/60 bg-background/40 px-4 py-5 focus-within:border-primary/45 focus-within:shadow-[0_0_0_3px_hsl(45_90%_55%/0.08)]">
                        <input type="number"
                               @bind="ViewModel.Amount"
                               @bind:event="oninput"
                               placeholder="@I18n.T("enter_amount")"
                               disabled="@ViewModel.IsProcessing"
                               class="w-full border-0 bg-transparent text-center font-display text-3xl font-bold text-foreground outline-none placeholder:text-muted-foreground/50" />
                    </div>
                    <div class="mt-3 flex gap-2">
                        @foreach (var v in Presets)
                        {
                            <button type="button"
                                    disabled="@ViewModel.IsProcessing"
                                    class="@PresetClass(v)"
                                    @onclick="() => ViewModel.SetPresetAmount(v)">
                                @v.ToString("N0")
                            </button>
                        }
                    </div>
                </div>

                <div class="flex items-center gap-3 rounded-2xl border border-border/50 bg-background/30 px-4 py-3.5">
                    <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-primary/10">
                        <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
                    </span>
                    <div class="min-w-0">
                        <p class="text-sm font-semibold text-foreground">@I18n.T("payment_method_momo")</p>
                        <p class="text-xs text-muted-foreground">@I18n.T("instant_deposit_momo")</p>
                    </div>
                </div>

                @if (ParsedAmount is { } amount && amount > 0)
                {
                    <div class="flex items-center justify-between rounded-xl border border-primary/20 bg-primary/5 px-4 py-3">
                        <span class="text-xs font-medium uppercase tracking-wider text-muted-foreground">@I18n.T("confirm_deposit")</span>
                        <span class="gold-text font-display text-lg font-bold">+@amount.ToString("N0") FCFA</span>
                    </div>
                }

                <PrimaryButton OnClick="Submit" Disabled="@(!ViewModel.CanSubmit)" CssClass="w-full !py-3.5 !text-sm">
                    @if (ViewModel.IsProcessing)
                    {
                        <span class="inline-flex items-center gap-2"><LoadingSpinner /> @I18n.T("processing")</span>
                    }
                    else
                    {
                        @I18n.T("confirm_deposit")
                    }
                </PrimaryButton>
            </div>
        }
    </div>
</div>

@code {
    private static readonly int[] Presets = [500, 1000, 2000, 5000];

    private decimal? ParsedAmount =>
        decimal.TryParse(ViewModel.Amount, out var value) ? value : null;

    protected override void OnInitialized() => ViewModel.StateChanged += OnStateChanged;
    public void Dispose() => ViewModel.StateChanged -= OnStateChanged;
    private void OnStateChanged() => InvokeAsync(StateHasChanged);
    private async Task Submit() => await ViewModel.SubmitAsync();

    private string PresetClass(int amount) =>
        ParsedAmount == amount
            ? "min-w-0 flex-1 rounded-xl border border-primary/40 bg-primary/15 py-2.5 text-xs font-semibold text-primary transition-all active:scale-[0.97] disabled:opacity-50"
            : "min-w-0 flex-1 rounded-xl border border-border/70 bg-background/35 py-2.5 text-xs font-semibold text-foreground transition-all hover:border-primary/40 hover:bg-primary/10 hover:text-primary active:scale-[0.97] disabled:opacity-50";
}
