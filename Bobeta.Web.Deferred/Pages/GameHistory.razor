@page "/history"
@using Bobeta.Client.Models.Api
@implements IDisposable
@inject GameHistoryViewModel ViewModel
@inject I18nService I18n

<div class="min-h-screen bg-background pb-24">
    <AppHeader Title="@I18n.T("game_history")" ShowBack="true" BackHref="/dashboard" />

    <div class="space-y-5 px-5">
        <ErrorBanner Message="@ViewModel.ErrorMessage" />

        @if (ViewModel.IsLoading && ViewModel.Items.Count == 0)
        {
            @for (var i = 0; i < 5; i++) { <SkeletonLoader CssClass="h-[5.5rem] rounded-2xl" /> }
        }
        else if (ViewModel.Items.Count == 0 && !ViewModel.IsLoading)
        {
            <div class="flex flex-col items-center gap-3 rounded-2xl border border-border/50 card-surface px-6 py-14 text-center">
                <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-muted/30">
                    <svg class="h-7 w-7 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                </div>
                <p class="font-display text-base font-semibold text-foreground">No games yet</p>
                <p class="max-w-[16rem] text-sm text-muted-foreground/90">Create or join a game to see your results here.</p>
                <a href="/create-game" class="mt-2 inline-flex items-center gap-1.5 rounded-xl bg-primary/15 px-4 py-2 text-sm font-semibold text-primary transition-all hover:bg-primary/20 active:scale-[0.98]">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                    @I18n.T("create_game")
                </a>
            </div>
        }
        else
        {
            @if (ViewModel.Items.Count > 0)
            {
                <div class="card-surface glow-gold overflow-hidden rounded-2xl border border-border/50 px-4 py-4">
                    <div class="mb-3 flex items-center gap-2">
                        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary/10">
                            <svg class="h-4 w-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
                        </span>
                        <p class="font-display text-sm font-semibold text-foreground">@I18n.T("game_history")</p>
                    </div>
                    <div class="flex divide-x divide-border/50 rounded-xl border border-border/40 bg-background/30">
                        <div class="min-w-0 flex-1 px-3 py-3.5 text-center">
                            <p class="font-display text-2xl font-bold text-foreground">@ViewModel.Items.Count</p>
                            <p class="mt-0.5 text-[11px] font-medium uppercase tracking-wide text-muted-foreground">@I18n.T("games")</p>
                        </div>
                        <div class="min-w-0 flex-1 px-3 py-3.5 text-center">
                            <p class="font-display text-2xl font-bold text-accent">@WinCount</p>
                            <p class="mt-0.5 text-[11px] font-medium uppercase tracking-wide text-muted-foreground">@I18n.T("wins")</p>
                        </div>
                        <div class="min-w-0 flex-1 px-3 py-3.5 text-center">
                            <p class="gold-text font-display text-2xl font-bold">@WinRateDisplay</p>
                            <p class="mt-0.5 text-[11px] font-medium uppercase tracking-wide text-muted-foreground">@I18n.T("win_rate")</p>
                        </div>
                    </div>
                </div>
            }

            <div class="flex flex-col gap-4 pt-1">
                @foreach (var item in ViewModel.Items)
                {
                    <article class="@RowCardClass(item) overflow-hidden rounded-2xl border p-4 transition-all">
                        <div class="flex items-start gap-3">
                            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl @RowIconBgClass(item)">
                                @RowIcon(item)
                            </div>

                            <div class="min-w-0 flex-1">
                                <div class="flex flex-wrap items-center gap-2">
                                    <span class="@RowStatusBadgeClass(item) inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-[11px] font-semibold uppercase tracking-wide">
                                        @if (item.Status == GameStatus.InProgress)
                                        {
                                            <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-current"></span>
                                        }
                                        @RowStatusLabel(item)
                                    </span>
                                    <span class="rounded-md bg-primary/10 px-2 py-0.5 text-[10px] font-semibold text-primary">@item.VariantName</span>
                                </div>

                                <div class="mt-1.5 flex items-baseline gap-1.5">
                                    <span class="gold-text font-display text-lg font-bold">@item.BetAmount.ToString("N0")</span>
                                    <span class="text-xs font-medium text-muted-foreground">FCFA stake</span>
                                </div>

                                @if (!string.IsNullOrEmpty(RowSubtitle(item)))
                                {
                                    <p class="mt-1 text-xs leading-relaxed text-muted-foreground/90">@RowSubtitle(item)</p>
                                }

                                <p class="mt-1.5 text-[11px] text-muted-foreground/70">@item.CreatedAt.ToString("MMM d, yyyy · h:mm tt")</p>

                                @if (item.Status == GameStatus.InProgress)
                                {
                                    <a href="@($"/game/{item.GameSessionId}")"
                                       class="mt-3 inline-flex items-center gap-1.5 rounded-lg gold-gradient px-3 py-1.5 text-xs font-semibold text-primary-foreground shadow transition-all active:scale-[0.97]">
                                        @I18n.T("history_continue")
                                        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                                    </a>
                                }
                            </div>

                            <div class="shrink-0 text-right">
                                <p class="font-display text-lg font-bold @RowAmountClass(item)">@RowAmountText(item)</p>
                                @if (RowIsWin(item))
                                {
                                    <p class="text-[10px] font-medium uppercase tracking-wide text-muted-foreground">FCFA</p>
                                }
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
    </div>
</div>

@code {
    private int WinCount => ViewModel.Items.Count(RowIsWin);
    private int FinishedCount => ViewModel.Items.Count(RowIsFinished);
    private string WinRateDisplay =>
        FinishedCount == 0
            ? "—"
            : $"{Math.Round(100.0 * WinCount / FinishedCount):0}%";

    protected override void OnInitialized() => ViewModel.StateChanged += OnStateChanged;
    protected override async Task OnInitializedAsync() => await ViewModel.LoadAsync();
    public void Dispose() => ViewModel.StateChanged -= OnStateChanged;
    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    private static bool RowIsFinished(GameHistoryItemDto item) => item.Status == GameStatus.Finished;

    private bool RowIsWin(GameHistoryItemDto item) => RowIsFinished(item) && (item.WonAmount ?? 0) > 0;

    private bool RowIsLoss(GameHistoryItemDto item) => RowIsFinished(item) && (item.WonAmount ?? 0) <= 0;

    private string RowStatusLabel(GameHistoryItemDto item) => item.Status switch
    {
        GameStatus.Finished => RowIsWin(item) ? I18n.T("won") : I18n.T("lost"),
        GameStatus.Waiting => I18n.T("history_waiting"),
        GameStatus.InProgress => I18n.T("history_live_game"),
        GameStatus.Cancelled => I18n.T("history_cancelled"),
        _ => item.Status.ToString()
    };

    private string RowSubtitle(GameHistoryItemDto item)
    {
        var role = item.IsCreator ? I18n.T("history_you_hosted") : I18n.T("history_you_joined");
        return item.Status switch
        {
            GameStatus.InProgress => $"{role}. {I18n.T("history_live_hint")}",
            GameStatus.Waiting or GameStatus.Cancelled => role,
            _ => ""
        };
    }

    private string RowCardClass(GameHistoryItemDto item) =>
        RowIsWin(item) ? "card-surface border-accent/25"
        : RowIsLoss(item) ? "card-surface border-destructive/20"
        : item.Status == GameStatus.InProgress ? "card-surface glow-gold border-primary/30"
        : "card-surface border-border/50";

    private string RowIconBgClass(GameHistoryItemDto item) =>
        RowIsWin(item) ? "bg-accent/15"
        : RowIsLoss(item) ? "bg-destructive/15"
        : item.Status == GameStatus.InProgress ? "bg-primary/15"
        : "bg-muted/25";

    private string RowStatusBadgeClass(GameHistoryItemDto item) =>
        RowIsWin(item) ? "bg-accent/15 text-accent"
        : RowIsLoss(item) ? "bg-destructive/15 text-destructive"
        : item.Status == GameStatus.InProgress ? "bg-primary/15 text-primary"
        : "bg-muted/30 text-muted-foreground";

    private string RowAmountClass(GameHistoryItemDto item) =>
        RowIsWin(item) ? "text-accent"
        : RowIsLoss(item) ? "text-destructive/80"
        : "text-muted-foreground/50";

    private string RowAmountText(GameHistoryItemDto item)
    {
        if (RowIsWin(item)) return $"+{((decimal)item.WonAmount!.Value):N0}";
        if (RowIsLoss(item)) return $"-{item.BetAmount:N0}";
        return "—";
    }

    private RenderFragment RowIcon(GameHistoryItemDto item) => __builder =>
    {
        if (RowIsWin(item))
        {
            <svg class="h-5 w-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
        }
        else if (RowIsLoss(item))
        {
            <svg class="h-5 w-5 text-destructive" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" /></svg>
        }
        else if (item.Status == GameStatus.InProgress)
        {
            <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        }
        else
        {
            <svg class="h-5 w-5 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        }
    };
}
