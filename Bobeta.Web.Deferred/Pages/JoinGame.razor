@page "/join"
@using Bobeta.Client.Models.Api
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject JoinGameViewModel ViewModel
@inject I18nService I18n
@inject IJSRuntime JS

<div class="min-h-screen bg-background pb-24">
    <div class="flex items-center gap-3 px-5 pt-6 pb-4">
        <a href="/dashboard" class="flex h-10 w-10 items-center justify-center rounded-xl bg-card transition-colors hover:bg-secondary">
            <svg class="h-5 w-5 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
        </a>
        <h1 class="font-display text-xl font-bold text-foreground">@I18n.T("join_game")</h1>
        <div class="ml-auto flex items-center gap-1.5 rounded-full border border-accent/25 bg-accent/10 px-3 py-1.5 text-xs font-semibold text-accent shadow-[0_0_16px_hsl(155_75%_45%/0.12)]">
            <span class="relative flex h-2 w-2">
                <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent opacity-60"></span>
                <span class="relative inline-flex h-2 w-2 rounded-full bg-accent"></span>
            </span>
            @ViewModel.OpenGames.Count @I18n.T("open")
        </div>
    </div>

    <div class="space-y-5 px-5">
        <ErrorBanner Message="@ViewModel.ErrorMessage" />

        <InviteCodePanel
            HasPendingCode="@(ViewModel.InviteStatus?.HasPendingCode == true)"
            PendingTitle="@(ViewModel.InviteStatus is { HasPendingCode: true } ? string.Format(I18n.T("invite_discount_banner"), ViewModel.InviteStatus.DiscountPercent.ToString("N0")) : "")"
            PendingDetail="@(ViewModel.InviteStatus is { HasPendingCode: true, Code: not null } ? string.Format(I18n.T("invite_code_label"), ViewModel.InviteStatus.Code) : null)"
            CodeInput="@ViewModel.InviteCodeInput"
            CodeInputChanged="OnInviteCodeChanged"
            OnApply="ViewModel.ApplyInviteCodeAsync"
            Disabled="@ViewModel.IsLoading"
            SuccessMessage="@ViewModel.InviteSuccessMessage" />

        <div class="card-surface rounded-2xl border border-border/50 p-1.5">
            <div class="grid grid-cols-3 gap-1 sm:grid-cols-5">
                <button type="button" class="@FilterClass(null)" @onclick="() => SetFilter(null)">
                    <span class="game-filter-icon game-filter-icon--all" aria-hidden="true">
                        <span></span><span></span><span></span><span></span>
                    </span>
                    <span>@I18n.T("filter_all_games")</span>
                </button>
                <button type="button" class="@FilterClass(GameVariant.Makopa)" @onclick="() => SetFilter(GameVariant.Makopa)">
                    <span class="game-filter-icon game-filter-icon--makopa" aria-hidden="true">
                        <span class="game-filter-icon__fan">
                            <span class="game-filter-icon__card game-filter-icon__card--red game-filter-icon__card--1">A</span>
                            <span class="game-filter-icon__card game-filter-icon__card--ink game-filter-icon__card--2">K</span>
                            <span class="game-filter-icon__card game-filter-icon__card--red game-filter-icon__card--3">7</span>
                            <span class="game-filter-icon__card game-filter-icon__card--ink game-filter-icon__card--4">Q</span>
                        </span>
                    </span>
                    <span>Makopa</span>
                </button>
                <button type="button" class="@FilterClass(GameVariant.Kopo)" @onclick="() => SetFilter(GameVariant.Kopo)">
                    <span class="game-filter-icon game-filter-icon--kopo" aria-hidden="true">
                        <span class="game-filter-icon__board">
                            @for (var i = 0; i < 16; i++)
                            {
                                var dark = (i / 4 + i % 4) % 2 == 0;
                                <span class="game-filter-icon__cell @(dark ? "game-filter-icon__cell--dark" : "game-filter-icon__cell--light")">
                                    @if (i is 5 or 10)
                                    {
                                        <span class="game-filter-icon__piece @(i == 5 ? "game-filter-icon__piece--gold" : "game-filter-icon__piece--white")"></span>
                                    }
                                </span>
                            }
                        </span>
                    </span>
                    <span>Kopo</span>
                </button>
                <button type="button" class="@FilterClass(GameVariant.Ngola)" @onclick="() => SetFilter(GameVariant.Ngola)">
                    <span class="game-filter-icon game-filter-icon--ngola" aria-hidden="true">
                        <span class="game-filter-icon__ngola">
                            @for (var pit = 0; pit < 8; pit++)
                            {
                                <span></span>
                            }
                        </span>
                    </span>
                    <span>Ngola</span>
                </button>
                <button type="button" class="@FilterClass(GameVariant.Domino)" @onclick="() => SetFilter(GameVariant.Domino)">
                    <span class="game-filter-icon game-filter-icon--domino" aria-hidden="true">
                        <span class="game-filter-icon__domino">
                            <span></span><span></span>
                        </span>
                    </span>
                    <span>Domino</span>
                </button>
                <button type="button" class="@FilterClass(GameVariant.Abbia)" @onclick="() => SetFilter(GameVariant.Abbia)">
                    <span class="game-filter-icon game-filter-icon--abbia" aria-hidden="true">
                        <span class="game-filter-icon__abbia">
                            <span></span><span></span><span></span>
                        </span>
                    </span>
                    <span>Abbia</span>
                </button>
            </div>
        </div>

        <div class="card-surface overflow-hidden rounded-2xl border border-border/50">
            <div class="flex items-center justify-between border-b border-border/40 px-4 py-3.5">
                <div class="flex items-center gap-2">
                    <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-primary/10">
                        <svg class="h-3.5 w-3.5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                    </span>
                    <div>
                        <p class="font-display text-sm font-semibold text-foreground">@I18n.T("open_game_sessions")</p>
                        <p class="text-[11px] text-muted-foreground">@ViewModel.OpenGames.Count @I18n.T("open")</p>
                    </div>
                </div>
                <button type="button"
                        class="inline-flex items-center gap-1.5 rounded-xl border border-primary/25 bg-primary/10 px-3 py-1.5 text-xs font-semibold text-primary transition-all hover:bg-primary/15 active:scale-[0.97] disabled:opacity-50"
                        @onclick="LoadGames"
                        disabled="@ViewModel.IsLoading">
                    <svg class="h-3.5 w-3.5 @(ViewModel.IsLoading ? "animate-spin" : "")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
                    @I18n.T("refresh")
                </button>
            </div>

            <div class="space-y-3 p-4">
                @if (ViewModel.IsLoading && ViewModel.OpenGames.Count == 0)
                {
                    @for (var i = 0; i < 3; i++)
                    {
                        <SkeletonLoader CssClass="h-[4.75rem] rounded-2xl" />
                    }
                }
                else if (ViewModel.OpenGames.Count == 0)
                {
                    <div class="flex flex-col items-center gap-3 px-4 py-10 text-center">
                        <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-primary/10 ring-1 ring-primary/20">
                            <svg class="h-7 w-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                        </div>
                        <p class="max-w-[18rem] text-sm text-muted-foreground/90">@I18n.T("no_open_games")</p>
                        <a href="/create-game" class="mt-1 inline-flex items-center gap-1.5 rounded-xl gold-gradient px-4 py-2.5 text-sm font-semibold text-primary-foreground shadow transition-all active:scale-[0.98]">
                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                            @I18n.T("create_game")
                        </a>
                    </div>
                }
                else
                {
                    @foreach (var game in ViewModel.OpenGames)
                    {
                        var g = game;
                        <GameSessionCard PlayerName="Player" BetAmount="(decimal)g.BetAmount" Variant="g.Variant" OnJoin="() => DoJoin(g.Id)" />
                    }
                }
            </div>
        </div>
    </div>
</div>

@code {
    private DotNetObjectReference<JoinGame>? _dotNetRef;
    private bool _visibilityHooked;

    protected override void OnInitialized() => ViewModel.StateChanged += OnStateChanged;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(ViewModel.LoadGamesAsync(), ViewModel.LoadInviteStatusAsync());
        ViewModel.StartLobbyRefresh();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _visibilityHooked)
            return;
        _visibilityHooked = true;
        _dotNetRef = DotNetObjectReference.Create(this);
        try
        {
            await JS.InvokeVoidAsync("bobeta.onVisibilityVisible", _dotNetRef);
        }
        catch (JSException)
        {
            // Older cached index.html without the helper — polling alone still works.
        }
        catch (JSDisconnectedException)
        {
        }
    }

    [JSInvokable]
    public Task OnTabBecameVisible() => ViewModel.LoadGamesAsync(forceRefresh: true, quiet: true);

    public async ValueTask DisposeAsync()
    {
        ViewModel.StopLobbyRefresh();
        ViewModel.StateChanged -= OnStateChanged;
        try
        {
            await JS.InvokeVoidAsync("bobeta.clearVisibilityVisible");
        }
        catch (JSException)
        {
        }
        catch (JSDisconnectedException)
        {
        }
        _dotNetRef?.Dispose();
        _dotNetRef = null;
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);
    private async Task LoadGames() => await ViewModel.LoadGamesAsync(forceRefresh: true);
    private async Task DoJoin(Guid gameId) => await ViewModel.JoinGameAsync(gameId);
    private void SetFilter(GameVariant? variant) => ViewModel.SetVariantFilter(variant);
    private void OnInviteCodeChanged(string value) => ViewModel.InviteCodeInput = value;

    private string FilterClass(GameVariant? variant) =>
        ViewModel.VariantFilter == variant
            ? "filter-selected flex flex-col items-center gap-1.5 rounded-xl border border-primary/40 bg-primary/15 px-2 py-2.5 text-[11px] font-semibold text-primary shadow-[inset_0_0_0_1px_hsl(45_90%_55%/0.25)] transition-all active:scale-[0.98]"
            : "flex flex-col items-center gap-1.5 rounded-xl border border-transparent px-2 py-2.5 text-[11px] font-medium text-muted-foreground transition-all hover:bg-secondary/60 hover:text-foreground active:scale-[0.98]";
}
