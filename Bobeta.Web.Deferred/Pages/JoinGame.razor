@page "/join"
@using Bobeta.Client.Models.Api
@implements IDisposable
@inject JoinGameViewModel ViewModel
@inject I18nService I18n

<div class="min-h-screen bg-background pb-24">
    <div class="flex items-center gap-3 px-5 pt-6 pb-4">
        <a href="/dashboard" class="flex h-10 w-10 items-center justify-center rounded-xl bg-card">
            <svg class="h-5 w-5 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
        </a>
        <h1 class="font-display text-xl font-bold text-foreground">@I18n.T("join_game")</h1>
        <div class="ml-auto flex items-center gap-1 rounded-lg bg-accent/10 px-2.5 py-1 text-xs font-medium text-accent">
            <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
            @ViewModel.OpenGames.Count @I18n.T("live")
        </div>
    </div>

    <div class="space-y-3 px-5">
        <ErrorBanner Message="@ViewModel.ErrorMessage" />
        <InviteCodePanel
            HasPendingCode="@(ViewModel.InviteStatus?.HasPendingCode == true)"
            PendingTitle="@(ViewModel.InviteStatus is { HasPendingCode: true } ? string.Format(I18n.T("invite_discount_banner"), ViewModel.InviteStatus.DiscountPercent.ToString("N0")) : "")"
            PendingDetail="@(ViewModel.InviteStatus is { HasPendingCode: true, Code: not null } ? string.Format(I18n.T("invite_code_label"), ViewModel.InviteStatus.Code) : null)"
            CodeInput="@ViewModel.InviteCodeInput"
            CodeInputChanged="OnInviteCodeChanged"
            OnApply="ViewModel.ApplyInviteCodeAsync"
            Disabled="@ViewModel.IsLoading"
            SuccessMessage="@ViewModel.InviteSuccessMessage" />
        <div class="flex flex-wrap gap-2">
            <button type="button" class="@FilterClass(null)" @onclick="() => SetFilter(null)">@I18n.T("filter_all_games")</button>
            <button type="button" class="@FilterClass(GameVariant.Makopa)" @onclick="() => SetFilter(GameVariant.Makopa)">Makopa</button>
            <button type="button" class="@FilterClass(GameVariant.Kopo)" @onclick="() => SetFilter(GameVariant.Kopo)">Kopo</button>
        </div>

        <div class="flex items-center justify-between">
            <p class="text-sm text-muted-foreground">@I18n.T("open_game_sessions")</p>
            <button type="button" class="flex items-center gap-1 text-xs text-primary hover:underline" @onclick="LoadGames" disabled="@ViewModel.IsLoading">
                <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
                @I18n.T("refresh")
            </button>
        </div>

        @if (ViewModel.IsLoading && ViewModel.OpenGames.Count == 0)
        {
            @for (var i = 0; i < 3; i++) { <SkeletonLoader CssClass="h-20 rounded-xl" /> }
        }
        else
        {
            @foreach (var game in ViewModel.OpenGames)
            {
                var g = game;
                <GameSessionCard PlayerName="Player" BetAmount="(decimal)g.BetAmount" Variant="g.Variant" OnJoin="() => DoJoin(g.Id)" />
            }
            @if (ViewModel.OpenGames.Count == 0 && !ViewModel.IsLoading)
            {
                <p class="text-sm text-muted-foreground py-4">No open games. <a href="/create-game" class="text-primary hover:underline">Create a game</a> to start.</p>
            }
        }
    </div>
</div>

@code {
    protected override void OnInitialized() => ViewModel.StateChanged += OnStateChanged;
    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(ViewModel.LoadGamesAsync(), ViewModel.LoadInviteStatusAsync());
    }
    public void Dispose() => ViewModel.StateChanged -= OnStateChanged;
    private void OnStateChanged() => InvokeAsync(StateHasChanged);
    private async Task LoadGames() => await ViewModel.LoadGamesAsync(forceRefresh: true);
    private async Task DoJoin(Guid gameId) => await ViewModel.JoinGameAsync(gameId);
    private void SetFilter(GameVariant? variant) => ViewModel.SetVariantFilter(variant);
    private void OnInviteCodeChanged(string value) => ViewModel.InviteCodeInput = value;

    private string FilterClass(GameVariant? variant) =>
        ViewModel.VariantFilter == variant
            ? "rounded-lg border-2 border-primary bg-primary/10 px-3 py-1.5 text-xs font-semibold text-primary"
            : "rounded-lg border border-border bg-card px-3 py-1.5 text-xs font-medium text-foreground";
}
