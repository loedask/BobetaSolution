@page "/withdraw"
@implements IDisposable
@inject WithdrawViewModel ViewModel
@inject I18nService I18n

<div class="min-h-screen bg-background pb-24">
    <AppHeader Title="@I18n.T("withdraw")" ShowBack="true" BackHref="/dashboard" />

    <div class="space-y-6 px-5">
        <ErrorBanner Message="@ViewModel.ErrorMessage" />
        <div class="card-surface rounded-2xl p-5">
            <div class="mb-1 flex items-center gap-2 text-sm text-muted-foreground">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" /></svg>
                <span>@I18n.T("available_balance")</span>
            </div>
            <span class="gold-text font-display text-3xl font-bold">@ViewModel.AvailableBalance.ToString("N0") FCFA</span>
        </div>

        @if (ViewModel.IsSuccess)
        {
            <div class="flex flex-col items-center gap-4 py-10">
                <svg class="h-16 w-16 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                <p class="font-display text-xl font-bold text-foreground">@I18n.T("withdrawal_successful")</p>
                <p class="text-sm text-muted-foreground">@ViewModel.SuccessAmount.ToString("N0") FCFA @I18n.T("sent_to_momo")</p>
            </div>
        }
        else
        {
            <div class="space-y-5">
                <div class="space-y-2">
                    <label class="text-sm font-medium text-foreground">@I18n.T("amount_fcfa")</label>
                    <input type="number" @bind="ViewModel.Amount" @bind:event="oninput" placeholder="@I18n.T("enter_amount")" disabled="@ViewModel.IsProcessing"
                           class="h-14 w-full rounded-xl border border-border bg-card text-center font-display text-2xl font-bold text-foreground placeholder:text-muted-foreground" />
                    <p class="text-xs text-muted-foreground">@I18n.T("min_withdrawal"): 200 FCFA · @I18n.T("max_withdrawal"): @ViewModel.AvailableBalance.ToString("N0") FCFA</p>
                </div>
                <div class="space-y-2">
                    <label class="text-sm font-medium text-foreground">@I18n.T("momo_number")</label>
                    <div class="flex items-center gap-3 rounded-xl border border-border bg-card px-4">
                        <svg class="h-4 w-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
                        <input type="tel" @bind="ViewModel.MomoNumber" disabled="@ViewModel.IsProcessing" class="h-12 flex-1 border-0 bg-transparent px-0 text-foreground outline-none" />
                    </div>
                </div>
                <PrimaryButton OnClick="Submit" Disabled="@(!ViewModel.CanSubmit)" CssClass="w-full">
                    @if (ViewModel.IsProcessing) { <span class="inline-flex items-center gap-2"><LoadingSpinner /> @I18n.T("processing")</span> }
                    else { @I18n.T("confirm_withdrawal") }
                </PrimaryButton>
            </div>
        }
    </div>
</div>

@code {
    protected override void OnInitialized() => ViewModel.StateChanged += OnStateChanged;
    public void Dispose() => ViewModel.StateChanged -= OnStateChanged;
    private void OnStateChanged() => InvokeAsync(StateHasChanged);
    private async Task Submit() => await ViewModel.SubmitAsync();
}
