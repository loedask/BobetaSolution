@page "/dashboard"
@implements IDisposable
@inject DashboardViewModel ViewModel
@inject I18nService I18n
@inject NavigationManager Nav

<div class="min-h-screen bg-background pb-24">
    <div class="flex items-center justify-between px-5 pt-6 pb-4">
        <div>
            <p class="text-sm text-muted-foreground">@I18n.T("welcome_back")</p>
            <h1 class="font-display text-xl font-bold text-foreground">@ViewModel.PlayerName</h1>
        </div>
        <button type="button" class="relative flex h-10 w-10 items-center justify-center rounded-xl bg-card">
            <svg class="h-5 w-5 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" /></svg>
            <div class="absolute -right-0.5 -top-0.5 h-2.5 w-2.5 rounded-full bg-accent"></div>
        </button>
    </div>

    <div class="space-y-6 px-5">
        @if (!string.IsNullOrEmpty(_sessionEndedMessage))
        {
            <div class="rounded-xl border border-primary/35 bg-primary/10 px-4 py-3 text-sm text-foreground">@_sessionEndedMessage</div>
        }
        <ErrorBanner Message="@ViewModel.ErrorMessage" />
        @if (ViewModel.ShowInvitePrompt)
        {
            <div class="rounded-2xl border border-primary/25 bg-primary/5 p-4">
                <div class="mb-2 flex items-start justify-between gap-3">
                    <div>
                        <p class="font-display text-sm font-semibold text-foreground">@I18n.T("invite_have_code")</p>
                        <p class="mt-1 text-xs text-muted-foreground">@I18n.T("invite_enter_hint")</p>
                    </div>
                    <button type="button"
                            class="shrink-0 text-xs font-medium text-muted-foreground hover:text-foreground"
                            @onclick="ViewModel.DismissInvitePromptAsync">
                        @I18n.T("invite_prompt_dismiss")
                    </button>
                </div>
                @if (!string.IsNullOrEmpty(ViewModel.InviteSuccessMessage))
                {
                    <p class="mb-2 text-xs text-accent">@ViewModel.InviteSuccessMessage</p>
                }
                <div class="flex gap-2">
                    <input class="flex-1 rounded-xl border border-border/60 bg-background/40 px-3 py-2.5 text-sm text-foreground outline-none focus:border-primary/50"
                           placeholder="@I18n.T("invite_enter_code")"
                           @bind="ViewModel.InviteCodeInput"
                           @bind:event="oninput" />
                    <button type="button"
                            class="rounded-xl bg-primary/15 px-4 py-2.5 text-sm font-semibold text-primary disabled:opacity-50"
                            disabled="@(ViewModel.IsLoading || string.IsNullOrWhiteSpace(ViewModel.InviteCodeInput))"
                            @onclick="ViewModel.ApplyInviteCodeAsync">
                        @I18n.T("invite_apply")
                    </button>
                </div>
            </div>
        }
        else if (ViewModel.InviteStatus is { HasPendingCode: true })
        {
            <div class="rounded-2xl border border-primary/30 bg-primary/10 px-4 py-3 text-sm text-foreground">
                <p class="font-medium">@string.Format(I18n.T("invite_pending_status"), ViewModel.InviteStatus.Code ?? "", ViewModel.InviteStatus.DiscountPercent.ToString("N0"))</p>
            </div>
        }
        @if (ViewModel.IsLoading && ViewModel.Transactions.Count == 0)
        {
            <div class="card-surface glow-gold rounded-2xl p-6">
                <SkeletonLoader CssClass="mb-2 h-4 w-32" />
                <SkeletonLoader CssClass="h-12 w-48" />
                <div class="mt-5 flex gap-3">
                    <SkeletonLoader CssClass="flex-1 h-12 rounded-xl" />
                    <SkeletonLoader CssClass="flex-1 h-12 rounded-xl" />
                </div>
            </div>
        }
        else
        {
            <WalletCard Balance="@((decimal)ViewModel.Balance)" OnDeposit="GoDeposit" OnWithdraw="GoWithdraw" />
        }

        <div class="grid grid-cols-3 gap-3">
            <a href="/create-game" class="gold-gradient flex flex-col items-center gap-2 rounded-xl p-4 transition-all active:scale-[0.97]">
                <svg class="h-6 w-6 text-primary-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                <span class="text-xs font-semibold text-primary-foreground">@I18n.T("create_game")</span>
            </a>
            <a href="/join" class="green-gradient flex flex-col items-center gap-2 rounded-xl p-4 transition-all active:scale-[0.97]">
                <svg class="h-6 w-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                <span class="text-xs font-semibold text-white">@I18n.T("join_game")</span>
            </a>
            <a href="/history" class="flex flex-col items-center gap-2 rounded-xl bg-secondary p-4 transition-all active:scale-[0.97]">
                <svg class="h-6 w-6 text-secondary-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                <span class="text-xs font-semibold text-secondary-foreground">@I18n.T("history")</span>
            </a>
        </div>

        <div class="card-surface rounded-2xl border border-border/50 p-4">
            <div class="mb-4 flex items-center justify-between">
                <h2 class="font-display text-base font-bold text-foreground">@I18n.T("recent_activity")</h2>
                <a href="/history" class="inline-flex items-center gap-1 text-xs font-semibold text-primary transition-colors hover:text-primary/80">
                    @I18n.T("see_all")
                    <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                </a>
            </div>
            <div class="space-y-2.5">
                @if (ViewModel.IsLoading && ViewModel.Transactions.Count == 0)
                {
                    @for (var i = 0; i < 3; i++) { <SkeletonLoader CssClass="h-[4.5rem] rounded-2xl" /> }
                }
                else if (ViewModel.Transactions.Count == 0)
                {
                    <div class="flex flex-col items-center gap-2 py-8 text-center">
                        <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-muted/30">
                            <svg class="h-6 w-6 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
                        </div>
                        <p class="text-sm text-muted-foreground">No recent activity</p>
                    </div>
                }
                @foreach (var tx in ViewModel.Transactions)
                {
                    <TransactionItem Description="@tx.Description" Time="@tx.Time" Amount="@tx.Amount" />
                }
            </div>
        </div>

        <div class="flex items-start gap-3 rounded-2xl border border-accent/20 bg-accent/5 p-4">
            <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-accent/15">
                <svg class="h-4 w-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            </div>
            <p class="text-xs leading-relaxed text-accent/90">@I18n.T("trust_message")</p>
        </div>
    </div>
</div>

@code {
    private string? _sessionEndedMessage;

    protected override void OnInitialized()
    {
        ViewModel.StateChanged += OnStateChanged;
        var query = Nav.ToAbsoluteUri(Nav.Uri).Query;
        if (query.Contains("message=", StringComparison.Ordinal))
        {
            var start = query.IndexOf("message=", StringComparison.Ordinal) + "message=".Length;
            var end = query.IndexOf('&', start);
            var raw = end < 0 ? query[start..] : query[start..end];
            _sessionEndedMessage = Uri.UnescapeDataString(raw);
        }
    }
    protected override async Task OnInitializedAsync() => await ViewModel.LoadAsync();
    public void Dispose() => ViewModel.StateChanged -= OnStateChanged;
    private void OnStateChanged() => InvokeAsync(StateHasChanged);
    private void GoDeposit() => ViewModel.GoToDeposit();
    private void GoWithdraw() => ViewModel.GoToWithdraw();
}
