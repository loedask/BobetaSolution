@page "/create-game"
@using Bobeta.Client.Models.Api
@implements IDisposable
@inject CreateGameViewModel ViewModel
@inject I18nService I18n

<div class="min-h-screen bg-background pb-44">
    <AppHeader Title="@I18n.T("create_game_session")" ShowBack="true" BackHref="/dashboard" />

    <div class="space-y-4 px-5">
        <p class="-mt-2 text-sm text-muted-foreground/90">@I18n.T("choose_bet_desc")</p>

        <ErrorBanner Message="@ViewModel.ErrorMessage" />

        <InviteCodePanel
            HasPendingCode="@(ViewModel.InviteStatus?.HasPendingCode == true)"
            PendingTitle="@DiscountTitle"
            PendingDetail="@DiscountDetail"
            CodeInput="@ViewModel.InviteCodeInput"
            CodeInputChanged="OnInviteCodeChanged"
            OnApply="ViewModel.ApplyInviteCodeAsync"
            Disabled="@ViewModel.IsLoading"
            SuccessMessage="@ViewModel.InviteSuccessMessage" />

        <div class="card-surface glow-gold overflow-hidden rounded-2xl border border-border/50">
            <section class="p-5">
                <div class="mb-4 flex items-center gap-2.5">
                    <span class="flex h-6 w-6 items-center justify-center rounded-full bg-primary/15 text-xs font-bold text-primary">1</span>
                    <h2 class="font-display text-sm font-semibold text-foreground">@I18n.T("select_game_type")</h2>
                </div>

                <div class="grid grid-cols-2 gap-3">
                    <button type="button" class="@VariantClass(GameVariant.Makopa)" @onclick="() => ViewModel.SetVariant(GameVariant.Makopa)">
                        <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-background/40">
                            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M4 7h16M4 12h16M4 17h10" /></svg>
                        </span>
                        <span class="font-display text-sm font-semibold">Makopa</span>
                    </button>
                    <button type="button" class="@VariantClass(GameVariant.Kopo)" @onclick="() => ViewModel.SetVariant(GameVariant.Kopo)">
                        <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-background/40">
                            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                        </span>
                        <span class="font-display text-sm font-semibold">Kopo</span>
                    </button>
                </div>
            </section>

            <div class="mx-5 h-px bg-border/60"></div>

            <section class="px-5 pb-5 pt-8">
                <div class="mb-1 flex items-center gap-2.5">
                    <span class="flex h-6 w-6 items-center justify-center rounded-full bg-primary/15 text-xs font-bold text-primary">2</span>
                    <h2 class="font-display text-sm font-semibold text-foreground">@I18n.T("select_bet_amount")</h2>
                </div>
                <p class="mb-4 ml-8 text-xs text-muted-foreground/90">@I18n.T("bet_range_fcfa")</p>

                <div class="grid grid-cols-2 gap-3">
                    @foreach (var amount in new[] { 200, 300, 400, 500 })
                    {
                        var a = amount;
                        <button type="button"
                                class="@PresetClass(a)"
                                @onclick="() => Pick(a)">
                            <span class="font-display text-lg font-bold">@a.ToString("N0")</span>
                            <span class="text-[11px] font-medium uppercase tracking-wide text-muted-foreground">FCFA</span>
                        </button>
                    }
                </div>

                <div class="mt-5 mb-4 rounded-xl border border-primary/20 bg-primary/5 px-4 py-4 text-center">
                    <p class="text-xs font-medium uppercase tracking-wider text-muted-foreground">@I18n.T("your_bet")</p>
                    <p class="gold-text mt-1 font-display text-3xl font-bold">@ViewModel.SelectedBet.ToString("N0") <span class="text-lg">FCFA</span></p>
                    @if (ViewModel.InviteStatus is { HasPendingCode: true } && ViewModel.EffectiveCharge < ViewModel.SelectedBet)
                    {
                        <p class="mt-2 text-xs text-muted-foreground">@string.Format(I18n.T("invite_you_pay"), ViewModel.EffectiveCharge.ToString("N0"))</p>
                    }
                </div>
            </section>
        </div>
    </div>

    <div class="fixed bottom-[calc(4.25rem+env(safe-area-inset-bottom,0px))] left-0 right-0 z-40 px-5">
        <div class="mx-auto max-w-lg rounded-2xl border border-border/40 bg-background/80 p-3 shadow-[0_-8px_32px_hsl(220_30%_4%/0.45)] backdrop-blur-xl">
            <PrimaryButton OnClick="Submit" Disabled="@(!ViewModel.CanSubmit)" CssClass="w-full !py-3.5 !text-sm">
                @if (ViewModel.IsLoading)
                {
                    <span class="inline-flex items-center gap-2"><LoadingSpinner /> @I18n.T("loading")</span>
                }
                else
                {
                    @I18n.T("create_game")
                }
            </PrimaryButton>
        </div>
    </div>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        ViewModel.StateChanged += OnStateChanged;
        await ViewModel.LoadInviteStatusAsync();
    }

    public void Dispose() => ViewModel.StateChanged -= OnStateChanged;
    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    private string DiscountTitle =>
        ViewModel.InviteStatus is { HasPendingCode: true }
            ? string.Format(I18n.T("invite_discount_banner"), ViewModel.InviteStatus.DiscountPercent.ToString("N0"))
            : "";

    private string? DiscountDetail =>
        ViewModel.InviteStatus is { HasPendingCode: true, Code: not null }
            ? string.Format(I18n.T("invite_code_label"), ViewModel.InviteStatus.Code)
            : null;

    private string VariantClass(GameVariant variant) =>
        ViewModel.SelectedVariant == variant
            ? "choice-selected flex flex-col items-center gap-2 rounded-xl border border-primary/40 px-3 py-4 text-primary transition-all active:scale-[0.98]"
            : "choice-unselected flex flex-col items-center gap-2 rounded-xl border border-border/80 px-3 py-4 text-foreground transition-all active:scale-[0.98]";

    private string PresetClass(decimal amount) =>
        ViewModel.SelectedBet == amount
            ? "choice-selected flex flex-col items-center justify-center rounded-xl border border-primary/40 py-4 text-primary transition-all active:scale-[0.98]"
            : "choice-unselected flex flex-col items-center justify-center rounded-xl border border-border/80 py-4 text-foreground transition-all active:scale-[0.98]";

    private void Pick(decimal amount) => ViewModel.SetBet(amount);

    private void OnInviteCodeChanged(string value) => ViewModel.InviteCodeInput = value;

    private async Task Submit() => await ViewModel.CreateAsync();
}
