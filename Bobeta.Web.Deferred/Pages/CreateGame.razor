@page "/create-game"
@using Bobeta.Client.Models.Api
@implements IDisposable
@inject CreateGameViewModel ViewModel
@inject I18nService I18n

<div class="min-h-screen bg-background pb-24">
    <div class="flex items-center gap-3 px-5 pt-6 pb-4">
        <a href="/dashboard" class="flex h-10 w-10 items-center justify-center rounded-xl bg-card">
            <svg class="h-5 w-5 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
        </a>
        <h1 class="font-display text-xl font-bold text-foreground">@I18n.T("create_game_session")</h1>
    </div>

    <div class="space-y-5 px-5">
        <ErrorBanner Message="@ViewModel.ErrorMessage" />

        <div class="card-surface rounded-2xl p-5">
            <p class="text-sm font-medium text-foreground">@I18n.T("select_game_type")</p>
            <div class="mt-3 grid grid-cols-2 gap-2">
                <button type="button" class="@VariantClass(GameVariant.Makopa)" @onclick="() => ViewModel.SetVariant(GameVariant.Makopa)">Makopa</button>
                <button type="button" class="@VariantClass(GameVariant.Kopo)" @onclick="() => ViewModel.SetVariant(GameVariant.Kopo)">Kopo</button>
            </div>
        </div>

        <div class="card-surface rounded-2xl p-5">
            <p class="text-sm font-medium text-foreground">@I18n.T("select_bet_amount")</p>
            <p class="mt-1 text-xs text-muted-foreground">@I18n.T("choose_bet_desc")</p>
            <p class="mt-2 text-xs text-muted-foreground">@I18n.T("bet_range_fcfa")</p>

            <div class="mt-4 grid grid-cols-2 gap-2">
                @foreach (var amount in new[] { 200, 300, 400, 500 })
                {
                    var a = amount;
                    <button type="button"
                            class="@PresetClass(a)"
                            @onclick="() => Pick(a)">
                        @a.ToString("N0") FCFA
                    </button>
                }
            </div>

            <p class="mt-5 text-center text-sm text-muted-foreground">@I18n.T("your_bet")</p>
            <p class="text-center font-display text-2xl font-bold text-primary">@ViewModel.SelectedBet.ToString("N0") FCFA</p>
        </div>

        <button type="button"
                class="gold-gradient w-full rounded-xl py-3.5 text-sm font-semibold text-primary-foreground transition-all active:scale-[0.98] disabled:opacity-50"
                disabled="@(!ViewModel.CanSubmit)"
                @onclick="Submit">
            @if (ViewModel.IsLoading)
            {
                <span>@I18n.T("loading")</span>
            }
            else
            {
                <span>@I18n.T("create_game")</span>
            }
        </button>
    </div>
</div>

@code {
    protected override void OnInitialized() => ViewModel.StateChanged += OnStateChanged;
    public void Dispose() => ViewModel.StateChanged -= OnStateChanged;
    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    private string VariantClass(GameVariant variant) =>
        ViewModel.SelectedVariant == variant
            ? "rounded-xl border-2 border-primary bg-primary/10 py-3 text-sm font-semibold text-primary"
            : "rounded-xl border border-border bg-card py-3 text-sm font-medium text-foreground";

    private string PresetClass(decimal amount) =>
        ViewModel.SelectedBet == amount
            ? "rounded-xl border-2 border-primary bg-primary/10 py-3 text-sm font-semibold text-primary"
            : "rounded-xl border border-border bg-card py-3 text-sm font-medium text-foreground";

    private void Pick(decimal amount) => ViewModel.SetBet(amount);

    private async Task Submit() => await ViewModel.CreateAsync();
}
