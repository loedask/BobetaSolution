@page "/my-waiting"
@using Bobeta.Client.Models.Api
@inject MyWaitingTablesViewModel ViewModel
@inject I18nService I18n
@implements IDisposable

<div class="min-h-screen bg-background pb-24">
    <div class="flex items-center gap-3 px-5 pt-6 pb-4">
        <a href="/dashboard" class="flex h-10 w-10 items-center justify-center rounded-xl bg-card transition-colors hover:bg-secondary">
            <svg class="h-5 w-5 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
        </a>
        <h1 class="font-display text-xl font-bold text-foreground">@I18n.T("my_waiting_tables")</h1>
    </div>

    <div class="space-y-5 px-5">
        <ErrorBanner Message="@ViewModel.ErrorMessage" />
        <p class="text-sm text-muted-foreground">@I18n.T("my_waiting_hint")</p>

        @if (ViewModel.IsLoading && ViewModel.WaitingTables.Count == 0)
        {
            @for (var i = 0; i < 2; i++)
            {
                <SkeletonLoader CssClass="h-20 rounded-2xl" />
            }
        }
        else if (ViewModel.WaitingTables.Count == 0)
        {
            <div class="flex flex-col items-center gap-2 rounded-2xl border border-border/50 bg-card/40 px-4 py-10 text-center">
                <p class="font-display text-sm font-semibold text-foreground">@I18n.T("my_waiting_empty_title")</p>
                <p class="text-xs text-muted-foreground">@I18n.T("my_waiting_empty_body")</p>
                <a href="/create-game" class="mt-3 gold-gradient inline-flex rounded-xl px-4 py-2.5 text-xs font-semibold text-primary-foreground">@I18n.T("create_game")</a>
            </div>
        }
        else
        {
            <div class="space-y-3">
                @foreach (var game in ViewModel.WaitingTables)
                {
                    var busy = ViewModel.BusyGameId == game.Id;
                    <div class="rounded-2xl border border-border/50 bg-background/30 p-3.5">
                        <div class="flex items-start justify-between gap-3">
                            <div class="min-w-0">
                                <div class="flex flex-wrap items-center gap-2">
                                    <span class="rounded-md bg-primary/15 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-primary">@GameVariantLabels.Name(game.Variant)</span>
                                    <span class="text-xs text-muted-foreground">@I18n.T("waiting_for_opponent_short")</span>
                                </div>
                                <div class="mt-2 gold-text font-display text-xl font-bold leading-none">@game.BetAmount.ToString("N0") <span class="text-[10px] font-medium uppercase tracking-wide text-muted-foreground">FCFA</span></div>
                            </div>
                            <div class="flex shrink-0 flex-col gap-2 sm:flex-row">
                                <button type="button"
                                        class="gold-gradient rounded-xl px-3.5 py-2.5 text-xs font-semibold text-primary-foreground disabled:opacity-50"
                                        disabled="@busy"
                                        @onclick="() => ViewModel.OpenTable(game.Id)">
                                    @I18n.T("open_table")
                                </button>
                                <button type="button"
                                        class="rounded-xl border border-border/60 bg-secondary/60 px-3.5 py-2.5 text-xs font-semibold text-foreground disabled:opacity-50"
                                        disabled="@busy"
                                        @onclick="() => ViewModel.CancelAsync(game.Id)">
                                    @(busy ? I18n.T("cancel") : I18n.T("cancel_table"))
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    protected override void OnInitialized() => ViewModel.StateChanged += OnStateChanged;
    protected override async Task OnInitializedAsync() => await ViewModel.LoadAsync();
    public void Dispose() => ViewModel.StateChanged -= OnStateChanged;
    private void OnStateChanged() => InvokeAsync(StateHasChanged);
}
