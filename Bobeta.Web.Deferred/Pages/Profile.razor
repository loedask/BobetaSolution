@page "/profile"
@implements IDisposable
@inject ProfileViewModel ViewModel
@inject I18nService I18n

<div class="min-h-screen bg-background pb-24">
    <AppHeader Title="@I18n.T("profile")" ShowBack="true" BackHref="/dashboard" />

    <div class="space-y-4 px-5">
        <div class="card-surface glow-gold overflow-hidden rounded-2xl border border-border/50 p-5">
            <div class="flex items-center gap-4">
                <div class="gold-gradient flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl shadow-lg">
                    <span class="font-display text-xl font-bold text-primary-foreground">@ViewModel.Initials</span>
                </div>
                <div class="min-w-0">
                    <h2 class="truncate font-display text-lg font-bold text-foreground">@ViewModel.PlayerName</h2>
                    <p class="mt-0.5 text-sm text-muted-foreground">@ViewModel.PhoneNumber</p>
                </div>
            </div>

            <div class="mt-5 grid grid-cols-3 divide-x divide-border/50 rounded-xl border border-border/40 bg-background/30">
                <div class="px-2 py-3 text-center">
                    @if (ViewModel.IsLoading)
                    {
                        <SkeletonLoader CssClass="mx-auto mb-1.5 h-6 w-8" />
                    }
                    else
                    {
                        <p class="font-display text-xl font-bold text-foreground">@(ViewModel.TotalGames == 0 ? "—" : ViewModel.TotalGames.ToString())</p>
                    }
                    <p class="text-[11px] font-medium uppercase tracking-wide text-muted-foreground">@I18n.T("games")</p>
                </div>
                <div class="px-2 py-3 text-center">
                    @if (ViewModel.IsLoading)
                    {
                        <SkeletonLoader CssClass="mx-auto mb-1.5 h-6 w-8" />
                    }
                    else
                    {
                        <p class="font-display text-xl font-bold text-accent">@(ViewModel.Wins == 0 && ViewModel.TotalGames == 0 ? "—" : ViewModel.Wins.ToString())</p>
                    }
                    <p class="text-[11px] font-medium uppercase tracking-wide text-muted-foreground">@I18n.T("wins")</p>
                </div>
                <div class="px-2 py-3 text-center">
                    @if (ViewModel.IsLoading)
                    {
                        <SkeletonLoader CssClass="mx-auto mb-1.5 h-6 w-10" />
                    }
                    else
                    {
                        <p class="gold-text font-display text-xl font-bold">@ViewModel.WinRateDisplay</p>
                    }
                    <p class="text-[11px] font-medium uppercase tracking-wide text-muted-foreground">@I18n.T("win_rate")</p>
                </div>
            </div>
        </div>

        <div class="card-surface rounded-2xl border border-border/50 p-5">
            <div class="mb-3 flex items-center gap-2">
                <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary/10">
                    <svg class="h-4 w-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" /></svg>
                </div>
                <span class="font-display text-sm font-semibold text-foreground">@I18n.T("invite_code")</span>
            </div>
            @if (ViewModel.InviteStatus is { HasPendingCode: true })
            {
                <p class="mb-3 text-sm text-muted-foreground">@string.Format(I18n.T("invite_pending_status"), ViewModel.InviteStatus.Code ?? "", ViewModel.InviteStatus.DiscountPercent.ToString("N0"))</p>
            }
            else
            {
                <p class="mb-3 text-sm text-muted-foreground">@I18n.T("invite_enter_hint")</p>
            }
            @if (!string.IsNullOrEmpty(ViewModel.InviteSuccessMessage))
            {
                <div class="portal-alert mb-3 rounded-xl border border-accent/30 bg-accent/10 px-3 py-2 text-sm text-accent">@ViewModel.InviteSuccessMessage</div>
            }
            <ErrorBanner Message="@ViewModel.ErrorMessage" />
            <div class="flex gap-2">
                <input class="flex-1 rounded-xl border border-border/60 bg-background/40 px-3 py-2.5 text-sm text-foreground outline-none focus:border-primary/50"
                       placeholder="@I18n.T("invite_enter_code")"
                       @bind="ViewModel.InviteCodeInput"
                       @bind:event="oninput" />
                <button type="button"
                        class="rounded-xl bg-primary/15 px-4 py-2.5 text-sm font-semibold text-primary disabled:opacity-50"
                        disabled="@(ViewModel.IsLoading || string.IsNullOrWhiteSpace(ViewModel.InviteCodeInput))"
                        @onclick="ViewModel.ApplyInviteCodeAsync">
                    @I18n.T("invite_apply")
                </button>
            </div>
        </div>

        <div class="card-surface rounded-2xl border border-border/50 p-5">
            <div class="mb-3 flex items-center gap-2">
                <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary/10">
                    <svg class="h-4 w-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0h.5a2.5 2.5 0 002.5-2.5V8.935M12 12a2 2 0 100 4 2 2 0 000-4z" /></svg>
                </div>
                <span class="font-display text-sm font-semibold text-foreground">@I18n.T("language")</span>
            </div>
            <LanguageSelector />
        </div>

        <div class="overflow-hidden rounded-2xl border border-border/50 card-surface">
            <a href="/dashboard" class="flex w-full items-center justify-between border-b border-border/40 p-4 transition-colors hover:bg-secondary/40 active:bg-secondary/60">
                <div class="flex items-center gap-3">
                    <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-primary/10">
                        <svg class="h-4 w-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" /></svg>
                    </div>
                    <span class="text-sm font-medium text-foreground">@I18n.T("wallet_settings")</span>
                </div>
                <svg class="h-4 w-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </a>
            <button type="button" class="flex w-full items-center justify-between p-4 transition-colors hover:bg-destructive/5 active:bg-destructive/10" @onclick="ViewModel.ShowSignOut">
                <div class="flex items-center gap-3">
                    <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-destructive/10">
                        <svg class="h-4 w-4 text-destructive" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
                    </div>
                    <span class="text-sm font-medium text-destructive">@I18n.T("sign_out")</span>
                </div>
                <svg class="h-4 w-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </button>
        </div>
    </div>
</div>

@if (ViewModel.ShowSignOutModal)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-background/80 backdrop-blur-sm px-6" @onclick="ViewModel.HideSignOut">
        <div class="card-surface w-full max-w-sm rounded-2xl border border-border/60 p-6 text-center shadow-2xl" @onclick:stopPropagation="true">
            <div class="mb-4 flex justify-center">
                <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-destructive/10">
                    <svg class="h-7 w-7 text-destructive" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
                </div>
            </div>
            <h3 class="mb-2 font-display text-lg font-bold text-foreground">@I18n.T("sign_out")?</h3>
            <p class="mb-6 text-sm text-muted-foreground">@I18n.T("sign_out_confirm")</p>
            <div class="flex gap-3">
                <button type="button" class="flex-1 rounded-xl border border-border bg-secondary/50 py-3 text-sm font-semibold text-foreground transition-all active:scale-[0.98]" @onclick="ViewModel.HideSignOut">@I18n.T("cancel")</button>
                <button type="button" class="flex-1 rounded-xl bg-destructive py-3 text-sm font-semibold text-destructive-foreground transition-all active:scale-[0.98]" @onclick="SignOut">@I18n.T("sign_out")</button>
            </div>
        </div>
    </div>
}

@code {
    protected override void OnInitialized() => ViewModel.StateChanged += OnStateChanged;
    protected override async Task OnInitializedAsync() => await ViewModel.LoadAsync();
    public void Dispose() => ViewModel.StateChanged -= OnStateChanged;
    private void OnStateChanged() => InvokeAsync(StateHasChanged);
    private async Task SignOut() => await ViewModel.SignOutAsync();
}
